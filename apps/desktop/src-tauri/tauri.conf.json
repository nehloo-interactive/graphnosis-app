{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Graphnosis",
  "version": "0.0.1",
  "identifier": "app.graphnosis",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @graphnosis-app/desktop dev",
    "beforeBuildCommand": "pnpm --filter @graphnosis-app/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Graphnosis",
        "width": 1180,
        "height": 760,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true,
        "visible": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "Personal second memory",
    "longDescription": "Local-first encrypted personal memory graph that attaches relevant context to your AI conversations."
  },
  "plugins": {}
}
