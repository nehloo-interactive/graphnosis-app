<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Child processes (sidecar, mcp-relay, biometric) inherit the parent sandbox.
       Must be signed with these entitlements for Apple's codesign to accept them
       as embedded helpers in a sandboxed .app bundle. -->
  <key>com.apple.security.app-sandbox</key>
  <true/>
  <key>com.apple.security.inherit</key>
  <true/>
</dict>
</plist>
