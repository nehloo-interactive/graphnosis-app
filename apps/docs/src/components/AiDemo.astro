---
const shots = [
  {
    src: '/screenshots/06-remember.png',
    alt: 'An AI client saving a new memory into Graphnosis',
    eyebrow: 'The remember loop',
    headline: 'Your AI saves a new memory — you choose where it goes.',
    caption: 'Before anything is written, Graphnosis asks which engram to route it to. You stay in control. Every write is explicit, auditable, and reversible.',
    offset: 'right',
    w: 1600,
    h: 1052,
  },
  {
    src: '/screenshots/07-recall.png',
    alt: 'An AI client recalling a memory from Graphnosis',
    eyebrow: 'The recall loop',
    headline: 'Any AI client. Same memory. No re-explaining.',
    caption: 'Later — in that session, in another client, weeks from now — any MCP-aware AI pulls from your encrypted graph and answers grounded in what you actually told it.',
    offset: 'left',
    w: 1600,
    h: 1040,
  },
];
---

<section id="ai-demo" class="py-24 bg-[#1c1c27] overflow-hidden">

  <div class="text-center mb-20 px-4 sm:px-6">
    <span class="block text-xs font-bold tracking-widest uppercase text-[#67e8f9] mb-4">The recall / remember loop</span>
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4">Watch your AI use it</h2>
    <p class="text-[#c4c6d6] max-w-2xl mx-auto text-base sm:text-lg leading-relaxed">
      Any MCP-aware AI client can read from and write to your Cortex. Tell it to remember something — Graphnosis asks which engram before it writes — and it's there the next time you ask, in that client or any other.
    </p>
  </div>

  <div class="flex flex-col gap-24">
    {shots.map((s) => (
      <figure class="flex flex-col items-center gap-8">

        <!-- Caption block -->
        <div class="text-center px-4 sm:px-6 max-w-2xl mx-auto">
          <p class="text-xs font-bold tracking-widest uppercase text-[#67e8f9] mb-3">{s.eyebrow}</p>
          <h3 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white leading-tight mb-3">{s.headline}</h3>
          <figcaption class="text-base sm:text-lg text-[#c4c6d6] leading-relaxed">{s.caption}</figcaption>
        </div>

        <!-- Image — offset Apple-style on desktop, full-width on mobile -->
        <div class="w-full overflow-hidden">
          <img
            src={s.src}
            alt={s.alt}
            width={s.w}
            height={s.h}
            loading="lazy"
            class={[
              'w-full sm:w-[125%] max-w-none block rounded-lg border border-[#2a2a3d]',
              s.offset === 'left' ? 'sm:ml-[-25%]' : 'sm:ml-0',
            ].join(' ')}
          />
        </div>

      </figure>
    ))}
  </div>

  <p class="text-xs text-[#555570] text-center mt-16 max-w-2xl mx-auto leading-relaxed px-4 sm:px-6">
    Claude is shown here to demonstrate the integration. All other product names, trademarks, and registered trademarks are the property of their respective owners.
    Graphnosis is not affiliated with, endorsed by, or sponsored by any third party.
  </p>

</section>
