---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

let version = '';
try {
  const conf = JSON.parse(readFileSync(resolve('../../apps/desktop/src-tauri/tauri.conf.json'), 'utf8'));
  version = conf.version ? `v${conf.version}` : '';
} catch {}
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-[#13131a]/90 border-b border-[#2a2a3d]">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Wordmark -->
      <a href="/" class="flex items-center gap-2.5 leading-tight">
        <img src="/graphnosis-logo.png" alt="Graphnosis logo" class="w-12 h-12 shrink-0" />
        <span class="flex flex-col">
          <span class="font-black text-lg text-[#67e8f9] tracking-tight">Graphnosis</span>
          <span class="hidden xl:block text-sm text-[#f0f0f5] font-normal tracking-wide">Local, private, encrypted, deterministic job memory</span>
        </span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-6">
        <a href="/memory-studio" class="text-sm font-semibold text-[#67e8f9] hover:text-[#a5f3fc] transition-colors">MemoryStudio</a>
        <a href="/skills-goals-trainer" class="text-sm font-semibold bg-clip-text text-transparent hover:opacity-80 transition-opacity" style="background-image: linear-gradient(90deg, #67e8f9 0%, #a78bfa 100%);">Skills + Goals</a>
        <a href="/job-memory-kits" class="text-sm text-[#a78bfa] hover:text-[#c4b5fd] font-semibold transition-colors">Job Memory Kits</a>
        <a href="/getting-started/overview" class="text-sm text-[#c4c6d6] hover:text-[#f0f0f5] transition-colors">Docs</a>
        <!-- Default href points to the chooser page (works when JS is off or OS
             is unknown). The inline script at the bottom rewrites href +
             label client-side based on detected OS. data-download-version
             carries the version string so the rewritten label can include
             "Download v1.X.Y for macOS" without re-reading tauri.conf.json. -->
        <a
          href="/download"
          class="inline-flex items-center px-4 py-2 rounded-full bg-[#67e8f9] hover:bg-[#4dd6e8] text-[#13131a] text-sm font-semibold transition-colors"
          data-download-auto
          data-download-version={version}
        >
          Download{version ? ` ${version}` : ''}
        </a>
      </div>

      <!-- Mobile hamburger (CSS-only focus-within trick) -->
      <div class="md:hidden flex items-center gap-3">
        {version && (
          <a href="/download" class="text-xs font-mono font-semibold px-2.5 py-1 rounded-full border border-[#67e8f9] text-[#67e8f9]" data-download-auto>{version}</a>
        )}
        <div class="relative" id="mobile-menu-container">
        <button
          id="mobile-menu-btn"
          aria-label="Toggle menu"
          class="flex flex-col gap-1.5 p-2 group"
          onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true'); document.getElementById('mobile-menu').classList.toggle('hidden');"
          aria-expanded="false"
        >
          <span class="block w-5 h-0.5 bg-[#f0f0f5] transition-transform"></span>
          <span class="block w-5 h-0.5 bg-[#f0f0f5] transition-opacity"></span>
          <span class="block w-5 h-0.5 bg-[#f0f0f5] transition-transform"></span>
        </button>
        </div>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-[#2a2a3d] mt-2 pt-4">
      <div class="flex flex-col gap-4">
        <a href="/memory-studio" class="text-sm font-semibold text-[#67e8f9]">MemoryStudio</a>
        <a href="/skills-goals-trainer" class="text-sm font-semibold bg-clip-text text-transparent" style="background-image: linear-gradient(90deg, #67e8f9 0%, #a78bfa 100%);">Skills + Goals</a>
        <a href="/job-memory-kits" class="text-sm text-[#a78bfa] font-semibold hover:text-[#c4b5fd] transition-colors">Job Memory Kits</a>
        <a href="/getting-started/overview" class="text-sm text-[#c4c6d6] hover:text-[#f0f0f5] transition-colors">Docs</a>
        <a
          href="/download"
          class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-[#67e8f9] hover:bg-[#4dd6e8] text-[#13131a] text-sm font-semibold transition-colors"
          data-download-auto
          data-download-version={version}
        >
          Download{version ? ` ${version}` : ''}
        </a>
      </div>
    </div>
  </nav>
</header>

<!--
  Universal Download-button OS detection.

  Any anchor on the page with `data-download-auto` opts into this:
    - default href stays `/download` (chooser fallback) until JS runs
    - on load, we detect the user's OS and rewrite href + label
    - if detection fails we leave the chooser fallback in place

  The data-download-version attribute (optional) carries the current
  Graphnosis version so the rewritten label reads
  "Download v1.X.Y for macOS" rather than just "Download for macOS".

  Mounted in Nav because Nav is rendered on every page that has a top
  download button. Pages that also want OS-aware buttons in their own
  body (Hero, memory-studio CTA, etc.) just need to add the same
  `data-download-auto` attribute and we wire them up here too.
-->
<script is:inline>
  (function () {
    function detectOs() {
      try {
        var uaData = (navigator).userAgentData;
        if (uaData && uaData.platform) {
          var p = uaData.platform.toLowerCase();
          if (p.indexOf('mac') !== -1) return 'mac';
          if (p.indexOf('win') !== -1) return 'win';
          if (p.indexOf('linux') !== -1) return 'linux';
        }
      } catch (_) { /* userAgentData unavailable */ }
      var plat = (navigator.platform || '').toLowerCase();
      if (plat.indexOf('mac') !== -1) return 'mac';
      if (plat.indexOf('win') !== -1) return 'win';
      if (plat.indexOf('linux') !== -1) return 'linux';
      var ua = (navigator.userAgent || '').toLowerCase();
      if (ua.indexOf('mac') !== -1) return 'mac';
      if (ua.indexOf('win') !== -1) return 'win';
      if (ua.indexOf('linux') !== -1) return 'linux';
      return null;
    }

    var os = detectOs();
    var links = document.querySelectorAll('a[data-download-auto]');
    if (!links.length) return;

    links.forEach(function (link) {
      var version = link.getAttribute('data-download-version') || '';
      // The micro-version pill in the mobile nav has only the version
      // as its visible text (no "Download" prefix); don't replace its
      // body, just point the href at the right OS.
      var isMicroPill = (link.textContent || '').trim() === version && version !== '';

      if (os === 'mac') {
        link.setAttribute('href', '/download/mac');
        if (!isMicroPill) {
          link.textContent = 'Download' + (version ? ' ' + version : '') + ' for macOS';
        }
      } else if (os === 'win') {
        link.setAttribute('href', '/download/win');
        if (!isMicroPill) {
          link.textContent = 'Download' + (version ? ' ' + version : '') + ' for Windows';
        }
      } else {
        // Linux or unknown — leave the href pointing at the chooser
        // page. The label gets a slightly more accurate suffix when
        // we know it's Linux (so the user understands their click
        // lands on a page that says "Linux coming soon").
        if (os === 'linux' && !isMicroPill) {
          link.textContent = 'Download' + (version ? ' ' + version : '') + ' — choose OS';
        }
      }
    });
  })();
</script>
