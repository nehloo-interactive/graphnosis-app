---

<section id="coming-soon" class="py-24 px-4 sm:px-6 bg-[#1c1c27]">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4">
        Graphnosis is synapsing.
      </h2>
      <p class="text-[#c4c6d6] max-w-xl mx-auto leading-relaxed">
        Local-first memory for every device you own. macOS, Windows and Linux are live today — mobile is on the roadmap.
      </p>
    </div>

    <!-- Platform cards. Available platforms link to the /download chooser;
         "coming soon" cards stay non-clickable (nothing to download yet). -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-6">
      {platforms.map((p) => {
        const isAvailable = p.status === 'available';
        const Tag = isAvailable ? 'a' : 'article';
        const href = isAvailable ? (p.href ?? '/download') : undefined;
        return (
        <Tag
          href={href}
          aria-label={isAvailable ? `Download Graphnosis for ${p.name}` : undefined}
          class={[
          'bg-[#13131a] border rounded-xl p-6 flex flex-col items-center text-center gap-4 no-underline',
          isAvailable
            ? 'border-[#67e8f9]/40 transition-all hover:border-[#67e8f9] hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[#67e8f9]/10'
            : 'border-[#2a2a3d]',
        ].join(' ')}>

          <!-- Platform icon -->
          <div class={[
            'w-14 h-14 rounded-xl flex items-center justify-center',
            p.status === 'available' ? 'text-[#67e8f9] bg-[#67e8f9]/10' : 'text-[#c4c6d6] bg-[#1c1c27]',
          ].join(' ')} aria-hidden="true" set:html={p.icon} />

          <!-- Platform name -->
          <span class="text-sm font-bold text-[#f0f0f5]">{p.name}</span>

          <!-- Status badge -->
          {p.status === 'available' ? (
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-400 text-xs font-semibold">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              {p.statusLabel}
            </span>
          ) : (
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-[#1c1c27] border border-[#2a2a3d] text-[#c4c6d6] text-sm font-semibold">
              {p.statusLabel}
            </span>
          )}

          <!-- Note -->
          <p class="text-sm text-[#c4c6d6] leading-snug">{p.note}</p>
        </Tag>
        );
      })}
    </div>

  </div>
</section>
