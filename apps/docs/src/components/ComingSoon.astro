---
const platforms = [
  {
    name: 'macOS',
    status: 'available',
    statusLabel: 'Available now',
    note: 'macOS 13 Ventura and later',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`,
  },
  {
    name: 'Windows',
    status: 'available',
    statusLabel: 'Available now',
    note: 'Windows 10 or later',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8" aria-hidden="true"><path d="M3 12V6.75l6-1.32v6.57H3zm17 0V5.25l-9 1.98V12h9zm-17 .75h6v6.43l-6-1.31v-5.12zm17 0h-9v5.77l9 1.98v-7.75z"/></svg>`,
  },
  {
    name: 'iOS',
    status: 'coming',
    statusLabel: 'Coming soon',
    note: 'Voice capture planned',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8" aria-hidden="true"><path d="M17 1.01L7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99zM17 19H7V5h10v14zm-4.2-5.78v1.75l3.2-2.99L12.8 9v1.7c-3.11.43-4.35 2.56-4.8 4.7 1.11-1.5 2.58-2.18 4.8-2.18z"/></svg>`,
  },
  {
    name: 'Android',
    status: 'coming',
    statusLabel: 'Coming soon',
    note: 'Android 14+',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8" aria-hidden="true"><path d="M6 18c0 .55.45 1 1 1h1v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h2v3.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5V19h1c.55 0 1-.45 1-1V8H6v10zm-2.5-1C2.67 17 2 17.67 2 18.5v-9C2 8.67 2.67 8 3.5 8S5 8.67 5 9.5v9c0 .83-.67 1.5-1.5 1.5zm17 0c-.83 0-1.5-.67-1.5-1.5v-9c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v9c0 .83-.67 1.5-1.5 1.5zM15.53 2.16l1.3-1.3c.2-.2.2-.51 0-.71-.2-.2-.51-.2-.71 0l-1.48 1.48C13.85 1.23 12.95 1 12 1c-.96 0-1.86.23-2.66.63L7.85.15c-.2-.2-.51-.2-.71 0-.2.2-.2.51 0 .71l1.31 1.31C7.15 3.23 6 5.01 6 7h12c0-1.99-1.15-3.77-2.47-4.84zM10 5H9V4h1v1zm5 0h-1V4h1v1z"/></svg>`,
  },
];
---

<section id="coming-soon" class="py-24 px-4 sm:px-6 bg-[#1c1c27]">
  <div class="max-w-7xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4">
        Graphnosis is synapsing.
      </h2>
      <p class="text-[#c4c6d6] max-w-xl mx-auto leading-relaxed">
        Local-first memory for every device you own. macOS is live today — other platforms are on the roadmap.
      </p>
    </div>

    <!-- Platform cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {platforms.map((p) => (
        <article class={[
          'bg-[#13131a] border rounded-xl p-6 flex flex-col items-center text-center gap-4',
          p.status === 'available' ? 'border-[#67e8f9]/40' : 'border-[#2a2a3d]',
        ].join(' ')}>

          <!-- Platform icon -->
          <div class={[
            'w-14 h-14 rounded-xl flex items-center justify-center',
            p.status === 'available' ? 'text-[#67e8f9] bg-[#67e8f9]/10' : 'text-[#c4c6d6] bg-[#1c1c27]',
          ].join(' ')} aria-hidden="true" set:html={p.icon} />

          <!-- Platform name -->
          <span class="text-sm font-bold text-[#f0f0f5]">{p.name}</span>

          <!-- Status badge -->
          {p.status === 'available' ? (
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-400 text-xs font-semibold">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              {p.statusLabel}
            </span>
          ) : (
            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-[#1c1c27] border border-[#2a2a3d] text-[#c4c6d6] text-sm font-semibold">
              {p.statusLabel}
            </span>
          )}

          <!-- Note -->
          <p class="text-sm text-[#c4c6d6] leading-snug">{p.note}</p>
        </article>
      ))}
    </div>

  </div>
</section>
