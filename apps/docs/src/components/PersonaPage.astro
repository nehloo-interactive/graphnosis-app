---
import PersonaBar from './PersonaBar.astro';
import HeroDiagram from './HeroDiagram.astro';

export type PersonaId = 'personal' | 'team' | 'business' | 'regulated' | 'enterprise' | 'air-gapped';

export interface UseCase {
  title: string;
  body: string;
}

export interface DocLink {
  label: string;
  href: string;
}

interface Props {
  active: PersonaId;
  headline: string;
  categories: string;    // e.g. "researchers · writers · developers"
  tagline: string;
  useCases: UseCase[];
  differentiators: string[];
  proHighlight: string;  // one sentence on what Pro unlocks for this persona
  links: DocLink[];
  cta: { label: string; href: string };
  sharedEngrams: string; // one-paragraph callout
}

const {
  active,
  headline,
  categories,
  tagline,
  useCases,
  differentiators,
  proHighlight,
  links,
  cta,
  sharedEngrams,
} = Astro.props;

const otherPersonas = [
  { id: 'personal',   label: 'Personal',   href: '/for/personal'   },
  { id: 'team',       label: 'Team',        href: '/for/team'       },
  { id: 'business',   label: 'Business',    href: '/for/business'   },
  { id: 'regulated',  label: 'Regulated',   href: '/for/regulated'  },
  { id: 'enterprise', label: 'Enterprise',  href: '/for/enterprise' },
  { id: 'air-gapped', label: 'Air-gapped',  href: '/for/air-gapped' },
].filter((p) => p.id !== active);
---

<div
  class="relative min-h-screen flex flex-col items-center text-left px-4 sm:px-6 pt-16 sm:pt-20 pb-24 overflow-hidden"
  style="background: #13131a;"
>
  <!-- Background glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 60% at 50% 20%, rgba(103,232,249,0.04) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-full max-w-4xl mx-auto">

    <!-- Wordmark + tagline -->
    <div class="text-center mb-10">
      <h2
        class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight bg-clip-text text-transparent"
        style="background-image: linear-gradient(135deg, #67e8f9 0%, #a78bfa 100%);"
      >Graphnosis</h2>
      <p class="mt-3 text-base sm:text-lg text-[#c4c6d6]">
        Local, encrypted, deterministic job memory — for professionals and the agents you build
      </p>
    </div>

    <!-- Persona bar -->
    <PersonaBar active={active} />

    <!-- Headline -->
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight tracking-tight mb-3">
      {headline}
    </h1>

    <!-- User categories — gradient left-to-right cyan→purple -->
    <p
      class="text-base sm:text-lg mb-5 tracking-wide font-medium bg-clip-text text-transparent"
      style="background-image: linear-gradient(90deg, #67e8f9 0%, #a78bfa 100%);"
    >{categories}</p>

    <!-- Tagline -->
    <p class="text-lg sm:text-xl text-[#c4c6d6] mb-10 max-w-2xl">{tagline}</p>

    <!-- Use-case cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
      {useCases.map((uc) => (
        <article class="bg-[#1c1c27] border border-[#2a2a3d] rounded-xl p-6">
          <h3 class="text-white font-bold text-lg mb-2">{uc.title}</h3>
          <p class="text-base text-[#c4c6d6]" set:html={uc.body} />
        </article>
      ))}
    </div>

    <!-- How Graphnosis fits -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-white mb-4">Why Graphnosis fits</h2>
      <ul class="space-y-3">
        {differentiators.map((d) => (
          <li class="flex gap-3 text-base text-[#c4c6d6]">
            <span class="mt-0.5 text-[#67e8f9] shrink-0">→</span>
            <span set:html={d} />
          </li>
        ))}
      </ul>
    </section>

    <!-- Shared engrams callout -->
    <section
      class="rounded-xl p-6 mb-10 border"
      style="background: rgba(103,232,249,0.04); border-color: rgba(103,232,249,0.15);"
    >
      <h2 class="text-sm font-bold text-[#67e8f9] uppercase tracking-widest mb-3">Shared Engrams</h2>
      <p class="text-base text-[#c4c6d6]" set:html={sharedEngrams} />
    </section>

    <!-- Pro spotlight -->
    <section
      class="rounded-xl p-6 mb-10 border"
      style="background: rgba(167,139,250,0.05); border-color: rgba(167,139,250,0.2);"
    >
      <h2 class="text-sm font-bold text-[#a78bfa] uppercase tracking-widest mb-3">Pro &amp; Teams</h2>
      <p class="text-base text-[#c4c6d6]" set:html={proHighlight} />
      <a
        href="/upgrade"
        class="inline-block mt-3 text-base font-semibold text-[#a78bfa] hover:text-white transition-colors"
      >
        See plans →
      </a>
    </section>

    <!-- Links — split: Docs (markdown content) vs Pages (Astro product pages) -->
    {(() => {
      const isDoc = (href: string) =>
        href.startsWith('/getting-started/') ||
        href.startsWith('/guides/') ||
        href.startsWith('/reference/') ||
        href === '/local-ai';
      const docs  = links.filter(l => isDoc(l.href));
      const pages = links.filter(l => !isDoc(l.href));
      const pillClass = "text-sm sm:text-base text-[#c4c6d6] border border-[#2a2a3d] rounded-full px-5 py-2.5 hover:border-[#67e8f9]/40 hover:text-white transition-colors";
      return (
        <div class="mb-12 space-y-8">
          {docs.length > 0 && (
            <section>
              <h2 class="text-xl font-bold text-white mb-4">Docs</h2>
              <div class="flex flex-wrap gap-3">
                {docs.map(l => <a href={l.href} class={pillClass}>{l.label}</a>)}
              </div>
            </section>
          )}
          {pages.length > 0 && (
            <section>
              <h2 class="text-xl font-bold text-white mb-4">Pages</h2>
              <div class="flex flex-wrap gap-3">
                {pages.map(l => <a href={l.href} class={pillClass}>{l.label}</a>)}
              </div>
            </section>
          )}
        </div>
      );
    })()}

    <!-- Primary CTA -->
    <div class="mb-16">
      <a
        href={cta.href}
        class="inline-block px-10 py-4 rounded-full font-bold text-base sm:text-lg text-[#13131a] transition-opacity hover:opacity-90"
        style="background: linear-gradient(135deg, #67e8f9 0%, #a78bfa 100%);"
      >
        {cta.label}
      </a>
    </div>

    <!-- Back to landing page -->
    <div
      class="rounded-xl p-5 mb-10 border text-center"
      style="background: rgba(255,255,255,0.02); border-color: #2a2a3d;"
    >
      <p class="text-sm text-[#c4c6d6] mb-3">
        Looking for the full picture — all use cases, how it works, AI clients, privacy details, and more?
      </p>
      <a
        href="/"
        class="inline-block text-sm sm:text-base font-semibold transition-colors"
        style="color: #67e8f9;"
      >
        See everything on the Graphnosis homepage →
      </a>
    </div>

    <!-- Diagram -->
    <div class="w-full mb-16">
      <HeroDiagram variant="b2b" persona={active} />
    </div>

    <!-- Also a fit? -->
    <footer class="border-t border-[#2a2a3d] pt-8 pb-4">
      <p class="text-base font-semibold text-[#c4c6d6] mb-4">Also a fit for:</p>
      <div class="flex flex-wrap gap-3">
        {otherPersonas.map((p) => (
          <a
            href={p.href}
            class="text-sm sm:text-base font-medium text-[#c4c6d6] border border-[#3a3a50] rounded-full px-5 py-2.5 hover:border-[#67e8f9]/40 hover:text-white transition-colors"
          >
            {p.label}
          </a>
        ))}
      </div>
    </footer>

  </div>
</div>
