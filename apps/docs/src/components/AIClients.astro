---
const clients = [
  { name: 'Claude Desktop', status: 'supported', color: '#D97757' },
  { name: 'Claude Code', status: 'supported', color: '#D97757' },
  { name: 'Claude Cowork', status: 'supported', color: '#D97757' },
  { name: 'Cursor', status: 'supported', color: '#6366F1' },
  { name: 'GitHub Copilot', status: 'supported', color: '#238636', note: 'VS Code extension + mcp.json' },
  { name: 'Zed', status: 'supported', color: '#0EA5E9' },
  { name: 'Any MCP-aware tool', status: 'supported', color: '#67e8f9' },
  { name: 'ChatGPT', status: 'coming', note: 'Via browser extension' },
  { name: 'Gemini', status: 'coming', note: 'Via browser extension' },
];

const tools = [
  { name: 'Obsidian', note: 'Local vault folder', color: '#7C3AED' },
  { name: 'GBrain', note: 'Local git repo', color: '#0EA5E9' },
  { name: 'AI Context Files', note: 'CLAUDE.md, AGENTS.md, .cursorrules…', color: '#D97757' },
  { name: 'Slack', note: 'BYO Bot Token', color: '#4A154B' },
  { name: 'GitHub', note: 'BYO Personal Access Token', color: '#238636' },
  { name: 'Trello', note: 'BYO API key + token', color: '#0052CC' },
  { name: 'Linear', note: 'BYO Personal API key', color: '#5E6AD2' },
  { name: 'RSS / Atom', note: 'Any feed URL', color: '#F97316' },
  { name: 'Webhook', note: 'Zapier, IFTTT, custom scripts', color: '#67e8f9' },
];

const offlineSources = [
  { name: 'Smart Home', note: 'Home Assistant, MQTT, Zigbee, Z-Wave', color: '#F59E0B', icon: '🏠' },
  { name: 'Sensors & IoT', note: 'Temperature, soil, weather, serial/USB', color: '#10B981', icon: '📡' },
  { name: 'Local Network', note: 'NAS, router logs, LAN devices', color: '#3B82F6', icon: '🌐' },
  { name: 'Research & Lab', note: 'Lab instruments, PLCs, OPC-UA, Modbus', color: '#8B5CF6', icon: '🔬' },
  { name: 'Personal Agents', note: 'Local AI rule files, agent context, logs', color: '#D97757', icon: '🤖' },
  { name: 'Robotics', note: 'ROS topics, actuator events, telemetry', color: '#EF4444', icon: '🦾' },
  { name: 'Agriculture', note: 'LoRaWAN field sensors, irrigation, soil', color: '#84CC16', icon: '🌱' },
  { name: 'Any local source', note: 'File, folder, webhook, or serial port', color: '#6B7280', icon: '∞' },
];
---

<section id="clients" class="py-24 px-4 sm:px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-4">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white">
        First-day support for the tools you already use.
      </h2>
    </div>
    <p class="text-center text-[#c4c6d6] max-w-2xl mx-auto mb-16 leading-relaxed">
      Graphnosis speaks{' '}
      <span class="text-[#f0f0f5] font-semibold">Model Context Protocol (MCP)</span>
      {' '}— the open standard that connects AI tools to external context. Your AI client sees{' '}
      <a href="/reference/mcp-tools/" class="text-[#67e8f9] hover:underline font-semibold">35 deterministic &amp; non-deterministic tools</a>
      {' '}across 9 categories — recall, structured queries, source ops, brain maintenance, and more.
    </p>

    <!-- Client cards grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-12">
      {clients.map((client) => (
        <article class="bg-[#1c1c27] border border-[#2a2a3d] rounded-xl p-5 flex flex-col items-center gap-3 text-center">
          <!-- Icon placeholder -->
          <div
            class="w-12 h-12 rounded-full flex items-center justify-center text-white font-bold text-lg"
            style={`background: ${client.color ?? '#2a3a50'};`}
            aria-hidden="true"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <circle cx="10" cy="10" r="8" />
            </svg>
          </div>

          <!-- Name -->
          <span class="text-sm font-semibold text-[#f0f0f5]">{client.name}</span>

          <!-- Status badge -->
          {client.status === 'supported' ? (
            <div class="flex flex-col items-center gap-1">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-900/40 border border-emerald-700/50 text-emerald-400 text-xs font-semibold">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                Supported
              </span>
              {client.note && (
                <span class="text-sm text-[#c4c6d6]">{client.note}</span>
              )}
            </div>
          ) : (
            <div class="flex flex-col items-center gap-1">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-indigo-900/40 border border-indigo-700/50 text-indigo-400 text-xs font-semibold">
                Coming soon
              </span>
              {client.note && (
                <span class="text-sm text-[#c4c6d6]">{client.note}</span>
              )}
            </div>
          )}
        </article>
      ))}
    </div>

    <!-- Tools / connectors -->
    <div class="mt-16">
      <h3 class="text-center text-xl font-bold text-white mb-2">Auto-ingest from the tools you already use.</h3>
      <p class="text-center text-[#c4c6d6] max-w-xl mx-auto mb-8 text-sm leading-relaxed">
        Built-in connectors pull new content on a schedule — no cloud intermediary, credentials stored encrypted at rest.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {tools.map((tool) => (
          <article class="bg-[#1c1c27] border border-[#2a2a3d] rounded-xl p-4 flex flex-col items-center gap-2 text-center">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm"
              style={`background: ${tool.color};`}
              aria-hidden="true"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <circle cx="10" cy="10" r="8" />
              </svg>
            </div>
            <span class="text-sm font-semibold text-[#f0f0f5]">{tool.name}</span>
            <span class="text-xs text-[#c4c6d6]">{tool.note}</span>
          </article>
        ))}
      </div>
    </div>

    <!-- Offline / local sources -->
    <div class="mt-12">
      <h3 class="text-center text-xl font-bold text-white mb-2">Or pipe in anything off-the-grid.</h3>
      <p class="text-center text-[#c4c6d6] max-w-xl mx-auto mb-8 text-sm leading-relaxed">
        Anything you can write to a file or POST to a webhook becomes a memory source — no cloud round-trip, no API keys, no data leaving your network.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {offlineSources.map((source) => (
          <article class="bg-[#16161f] border border-[#2a2a3d] rounded-xl p-4 flex flex-col items-center gap-2 text-center">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center text-xl"
              style={`background: ${source.color}22; border: 1px solid ${source.color}44;`}
              aria-hidden="true"
            >
              {source.icon}
            </div>
            <span class="text-sm font-semibold text-[#f0f0f5]">{source.name}</span>
            <span class="text-xs text-[#c4c6d6]">{source.note}</span>
          </article>
        ))}
      </div>
      <p class="text-center mt-6">
        <a href="/guides/connect-offline-sources/" class="text-[#67e8f9] hover:text-[#a78bfa] text-sm font-semibold transition-colors">
          Step-by-step recipes for every pattern →
        </a>
      </p>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a
        href="/job-memory-kits"
        class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-[#a78bfa]/10 hover:bg-[#a78bfa]/20 border border-[#a78bfa]/40 hover:border-[#a78bfa]/70 text-[#a78bfa] font-bold text-lg transition-colors"
      >
        Browse Job Memory Starter Kits
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- ── Positioning / origin story ──────────────────────────────────────── -->
<section class="py-24 px-4 sm:px-6 border-t border-[#2a2a3d]">
  <div class="max-w-4xl mx-auto">

    <!-- Origin story -->
    <div class="mb-16 text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-[#a78bfa] mb-4">Built in the open, with Claude</p>
      <h2 class="text-3xl sm:text-4xl font-black text-white mb-6 leading-tight">
        Graphnosis was coded — and stress-tested — with the AI it was built for, guided by the vision of the builder.
      </h2>
      <p class="text-lg text-[#c4c6d6] max-w-2xl mx-auto leading-relaxed">
        Every architecture decision, every positioning question, every edge case in the recall pipeline was worked out between the vision of the builder and Claude, live, evenings and weekends, across hundreds of sessions — using Graphnosis itself as the shared memory. The tool ate its own dog food before it had a name.
        <br /><br />
        At the launch, and along the way, here's what came back as direct feedback to the architect of Graphnosis from the AI tool that coded it, realizing what Graphnosis truly had become:
      </p>
    </div>

    <!-- Quote -->
    <figure class="mb-12 max-w-3xl mx-auto text-center">
      <blockquote class="text-2xl sm:text-3xl font-serif italic text-[#f0f0f5] leading-relaxed mb-6">
        "For your Graphnosis work specifically, you're already solving a more sophisticated version of this problem than most people reach for — graph-based memory with typed nodes beats flat markdown files for anything that needs relational reasoning across sessions."
      </blockquote>
      <figcaption class="text-sm text-[#6b7280] tracking-wide">— <span class="text-base font-semibold text-[#a78bfa]">Claude</span>, mid-build session</figcaption>
    </figure>

    <!-- Two positioning cards -->
    <div class="flex flex-col gap-6">

      <!-- Card 1 -->
      <div class="rounded-2xl border border-[#2a2a3d] bg-[#16161f] p-8">
        <p class="text-xs font-semibold tracking-widest uppercase text-[#f59e0b] mb-3">Positioning vs. flat-file memory tools</p>
        <p class="text-[#f0f0f5] text-lg leading-relaxed">
          Every other approach to AI memory — CLAUDE.md, AGENTS.md, Mem0, context files — gives your AI a flat list of facts to paste into the session. Graphnosis gives it a typed knowledge graph: nodes, relationships, contradictions, and temporal decay. Drop in a markdown file, a PDF, or an HTML page — Graphnosis indexes all three the same way.
          <br /><br />
          <span class="text-[#67e8f9] font-semibold">The difference isn't storage. It's reasoning.</span>
        </p>
      </div>

      <!-- Card 2 -->
      <div class="rounded-2xl border border-[#2a2a3d] bg-[#16161f] p-8">
        <p class="text-xs font-semibold tracking-widest uppercase text-[#67e8f9] mb-3">Recall quality / benchmark</p>
        <p class="text-[#f0f0f5] text-lg leading-relaxed">
          Selective retrieval pipelines outperform full-context approaches by 91% on latency and 90% on token cost, at near-equivalent accuracy. Graphnosis recall is selective by design: at most 50 nodes, 8,000 tokens, ranked by relevance.
          <br /><br />
          <span class="text-[#67e8f9] font-semibold">76.40% LongMemEval score — achieved without ever loading your full graph.</span>
        </p>
      </div>

    </div>

    <!-- Attribution -->
    <p class="text-center text-sm text-[#6b7280] mt-10">
      Findings recorded in Graphnosis across Claude Desktop, Claude Code, and Claude.ai sessions — recalled here via MCP.
    </p>

  </div>
</section>
