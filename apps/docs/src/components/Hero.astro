    tx(160, 296, 'Linear · RSS',            C.white,  12);
    tx(160, 310, 'Trello · Webhook',        C.white,  12);
    tx(160, 324, 'Sensors · MQTT',          C.tools,  12);
    tx(160, 338, 'NAS · PDF scans',         C.tools,  12);
    tx(160, 352, 'Obsidian · GBrain',       C.white,  12);
    tx(160, 366, 'CLAUDE.md · AGENTS.md',   C.white,  12);
    tx(160, 380, 'CURSOR_RULES · GEMINI.md', C.white, 12);
    amber( 85, 283, words[0], 11);
    amber( 85, 297, words[1], 11);
    amber(232, 283, words[2], 11);
    amber(232, 297, words[3], 11);

    // ── AI agents box text (cx=500) ──
    tx(500, 260, '⚡',               C.ai,    22);
    tx(500, 277, 'AI agents',        C.ai,    15, '700');
    amber(500, 293, pair.a1,         11);
    amber(500, 307, pair.a2,         11);
    tx(500, 322, 'Claude agents',    C.white,  12);
    tx(500, 337, 'n8n · LangChain',  C.white,  12);
    tx(500, 352, 'custom workflows', C.white,  12);
    tx(500, 372, 'same cortex',      C.human,  13);

    // ── Clients box text (cx=840) ──
