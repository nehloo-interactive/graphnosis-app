<Layout
  title="Graphnosis Starter Kits — Pre-built memory for your profession"
  description="Starter kits for Graphnosis: named recall patterns, engram schemas, and workflow guides pre-configured for your profession. Zero data. No servers."
>
  <Nav />
  <main>

    <!-- Header -->
    <section class="py-20 px-4 sm:px-6 text-center">
      <div class="max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#2a2a3d] bg-[#1c1c27] text-[#a78bfa] text-xs font-semibold tracking-widest uppercase mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#a78bfa]"></span>
          Starter Kits
        </div>
        <h1 class="text-4xl sm:text-5xl font-black mb-4 leading-tight">
          <span class="bg-clip-text text-transparent" style="background-image: linear-gradient(135deg, #67e8f9 0%, #a78bfa 100%);">
            Job Memory Starter Kits
          </span>
        </h1>
        <p class="text-[#c4c6d6] text-lg leading-relaxed mb-4 max-w-2xl mx-auto">
          Start with your profession's starter kit — a named set of recall patterns, an engram schema,
          and a setup guide configured for how your specific job actually uses memory.
        </p>
        <p class="text-[#c4c6d6] text-sm mb-8">
          One-time purchase · Yours forever · Works with the free Graphnosis download
        </p>

        <!-- Zero data · zero servers callout -->
        <div class="bg-[#1c1c27] border border-[#2a2a3d] rounded-xl p-5 text-left flex gap-4 items-start max-w-2xl mx-auto">
          <svg class="w-5 h-5 shrink-0 mt-0.5 text-[#67e8f9]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          <div>
            <p class="text-[#f0f0f5] font-semibold text-sm mb-1">These packs contain zero actual data. Graphnosis has zero servers.</p>
            <p class="text-[#c4c6d6] text-sm leading-relaxed">
              A pack is a structure: engram schemas, recall patterns, and connector guides. Your memory is
              built from your own files, on your own device. Nothing is pre-loaded, nothing is shared,
              and no Graphnosis server ever touches it.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Filter bar -->
    <section class="px-4 sm:px-6 pb-8 sticky top-16 z-40 bg-[#13131a]/95 backdrop-blur-md border-b border-[#2a2a3d]">
      <div class="max-w-7xl mx-auto pt-4 flex flex-col sm:flex-row gap-3">
        <!-- Search -->
        <div class="relative shrink-0 sm:w-56">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#52525b]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <input
            id="pack-search"
            type="search"
            placeholder="Search packs…"
            class="w-full pl-9 pr-3 py-2 rounded-full bg-[#1c1c27] border border-[#2a2a3d] focus:border-[#67e8f9] focus:outline-none text-[#f0f0f5] placeholder-[#52525b] text-sm transition-colors"
          />
        </div>
        <!-- Category chips -->
        <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-none">
          {categories.map((cat) => (
            <button
              class="category-chip shrink-0 px-3 py-1.5 rounded-full text-xs font-semibold border transition-colors whitespace-nowrap"
              data-category={cat.id}
              style={cat.id === 'all'
                ? 'background:#67e8f9; color:#13131a; border-color:#67e8f9;'
                : 'background:transparent; color:#c4c6d6; border-color:#2a2a3d;'}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Pack grid -->
    <section class="py-12 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">

        <!-- Count -->
        <p id="pack-count" class="text-xs text-[#52525b] font-mono mb-6">{packs.length} packs</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="pack-grid">
          {packs.map((pack) => {
            const color = catColor[pack.category] ?? '#67e8f9';
            const searchText = [pack.name, pack.tagline, ...pack.skills].join(' ').toLowerCase();
            return (
              <article
                class="pack-card bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-6 flex flex-col gap-4 relative"
                data-category={pack.category}
                data-search-text={searchText}
                style={`border-color: ${color}18;`}
              >
                {pack.badge && (
                  <div
                    class="absolute -top-3 left-5 text-xs font-black tracking-widest uppercase px-3 py-1 rounded-full text-[#13131a]"
                    style={`background: ${color};`}
                  >
                    {pack.badge}
                  </div>
                )}

                <!-- Category label + name -->
                <div>
                  <p class="text-xs font-black tracking-widest uppercase mb-1" style={`color: ${color};`}>
                    {categories.find(c => c.id === pack.category)?.label}
                  </p>
                  <h2 class="text-lg font-black text-white leading-snug">{pack.name}</h2>
                  <p class="text-xs text-[#52525b] mt-0.5">{pack.tagline}</p>
                </div>

                <!-- Skills -->
                <ul class="flex flex-col gap-2 flex-1">
                  {pack.skills.map((skill) => {
                    const [title, ...rest] = skill.split(' — ');
                    return (
                      <li class="flex items-start gap-2 text-sm text-[#c4c6d6]">
                        <span
                          class="mt-0.5 w-3.5 h-3.5 shrink-0 rounded-full flex items-center justify-center"
                          style={`background: ${color}18; border: 1px solid ${color}33;`}
                        >
                          <svg class="w-2 h-2" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true" style={`color: ${color};`}>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                          </svg>
                        </span>
                        <span>
                          <span class="font-semibold text-[#f0f0f5]">{title}</span>
                          {rest.length > 0 && <span class="text-[#c4c6d6]"> — {rest.join(' — ')}</span>}
                        </span>
                      </li>
                    );
                  })}
                </ul>

                <!-- Trust strip -->
                <div class="flex items-center gap-3 pt-3 border-t border-[#2a2a3d]">
                  <span class="text-xs text-[#52525b]">Zero data included</span>
                  <span class="text-[#2a2a3d]" aria-hidden="true">·</span>
                  <span class="text-xs text-[#52525b]">No Graphnosis servers</span>
                </div>

                <!-- Price + CTA -->
                <div class="flex items-center justify-between gap-4">
                  <span class="text-3xl font-black text-white">${pack.price}</span>
                  <a
                    href={pack.stripeUrl}
                    class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-full font-bold text-sm transition-opacity hover:opacity-90 text-[#13131a]"
                    style={`background: ${color};`}
                  >
                    Get pack
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>

        <!-- No results -->
        <p id="no-results" class="hidden text-center text-[#52525b] py-16 text-sm">
          No packs match that search. <a href="mailto:templates@graphnosis.com" class="text-[#67e8f9] underline">Request one →</a>
        </p>

      </div>
    </section>

    <!-- Team licence CTA -->
    <section class="pb-16 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-8 text-center">
        <h2 class="text-2xl font-black text-white mb-3">Need this for a whole team?</h2>
        <p class="text-[#c4c6d6] mb-6 max-w-lg mx-auto">
          Individual licences cover a single user. For firm-wide or team deployments — where multiple
          people import the same schema — contact us for an organisational licence.
        </p>
        <a
          href="mailto:templates@graphnosis.com"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#67e8f9] hover:bg-[#4dd6e8] text-[#13131a] font-bold text-base transition-colors"
        >
          Contact for team licensing
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="pb-24 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl font-black text-white mb-8">Frequently asked</h2>
        <div class="flex flex-col gap-6">
          {[
            {
              q: 'What is a starter kit?',
              a: 'A pre-configured starting point for Graphnosis memory in your specific domain. Each kit includes: an engram schema (which engrams to create and at which sensitivity tier); named recall patterns (the query approach for your professional context); a connector guide (how to ingest your specific sources); and an AI session template (the context file for any AI client — Claude, Cursor, Copilot, or your own agent). These kits will eventually be published as a standalone product called Job Gnosis.',
            },
            {
              q: 'Do I need a pack to use Graphnosis?',
              a: "No. Graphnosis is free and fully functional without any pack. Packs save you the setup time of figuring out the right memory structure and recall patterns for your specific job. Everything in a pack can be built manually — the pack means you don't have to.",
            },
            {
              q: 'Why does it say zero data and no servers?',
              a: "Because it's true and it matters. The pack contains no pre-loaded memory — it's a schema and a guide. Your memory is built from your own files on your own machine. Graphnosis has no cloud infrastructure: no sync server, no ingestion API, no telemetry. The source code is available to verify this.",
            },
            {
              q: 'What do I receive after purchase?',
              a: 'A ZIP with: the engram schema (importable directly into Graphnosis); a recall pattern guide formatted for any AI client context file; a source integration guide for the tools most common in your profession; and a setup walkthrough. Delivered immediately via Stripe.',
            },
            {
              q: "My profession isn't listed.",
              a: "Email templates@graphnosis.com with your profession and the 3–4 situations where you most need AI to remember what you know. We'll either build the pack or point you to the closest existing one.",
            },
          ].map((item) => (
            <div class="border-b border-[#2a2a3d] pb-6">
              <h3 class="text-base font-bold text-white mb-2">{item.q}</h3>
              <p class="text-[#c4c6d6] text-base leading-relaxed">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.category-chip');
  const cards = document.querySelectorAll<HTMLElement>('.pack-card');
  const search = document.getElementById('pack-search') as HTMLInputElement;
  const noResults = document.getElementById('no-results') as HTMLElement;
  const countEl = document.getElementById('pack-count') as HTMLElement;

  let activeCategory = 'all';

  function filter() {
    const q = search.value.toLowerCase().trim();
    let visible = 0;
    cards.forEach(card => {
      const matchesCat = activeCategory === 'all' || card.dataset.category === activeCategory;
      const matchesSearch = !q || (card.dataset.searchText ?? '').includes(q);
      const show = matchesCat && matchesSearch;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    noResults.classList.toggle('hidden', visible > 0);
    countEl.textContent = visible === cards.length
      ? `${cards.length} packs`
      : `${visible} of ${cards.length} packs`;
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => {
        c.style.cssText = 'background:transparent; color:#c4c6d6; border-color:#2a2a3d;';
      });
      chip.style.cssText = 'background:#67e8f9; color:#13131a; border-color:#67e8f9;';
      activeCategory = chip.dataset.category ?? 'all';
      filter();
    });
  });

  search.addEventListener('input', filter);
</script>
