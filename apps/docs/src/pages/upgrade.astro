---
/**
 * GET /upgrade
 *
 * Pricing page for Graphnosis. Shows Free, Pro, and Teams tiers.
 * Routes to /upgrade/checkout with the correct ?plan= parameter.
 *
 * Query params (all optional, forwarded to /upgrade/checkout):
 *   ?email=...    Pre-fill Stripe checkout with the cortex email.
 */

export const prerender = false;

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PersonaBar from '../components/PersonaBar.astro';
import '../styles/global.css';

const url = new URL(Astro.request.url);
const prefilledEmail = url.searchParams.get('email') ?? '';

const emailParam = prefilledEmail ? `&email=${encodeURIComponent(prefilledEmail)}` : '';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Graphnosis — Pricing</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Graphnosis pricing: Free forever, Pro at $10/mo, Teams at $25/mo. Local-first AI memory with no data ever leaving your machine." />
    <style>
      :root {
        --bg: #0f1411;
        --fg: #e7eee8;
        --fg-dim: #8b9590;
        --accent: #1bb673;
        --accent-dark: #169b62;
        --card: #18211c;
        --border: #233028;
      }
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        padding: 0;
        line-height: 1.6;
      }
      .page-content {
        max-width: 820px;
        margin: 0 auto;
        padding: 0 24px 8vh;
      }
      /* ── Hero ── */
      .hero {
        text-align: center;
        padding: 72px 0 56px;
        position: relative;
      }
      .hero::before {
        content: '';
        position: absolute;
        top: 0; left: 50%;
        transform: translateX(-50%);
        width: 640px; height: 280px;
        background: radial-gradient(ellipse at center, rgba(27,182,115,0.09) 0%, transparent 68%);
        pointer-events: none;
      }
      .eyebrow-pill {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 5px 16px;
        border: 1px solid rgba(27,182,115,0.45);
        border-radius: 100px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 22px;
      }
      .eyebrow-pill::before {
        content: '';
        width: 6px; height: 6px;
        border-radius: 50%;
        background: var(--accent);
        flex-shrink: 0;
      }
      h1 {
        font-size: 50px;
        line-height: 1.1;
        margin: 0 0 18px;
        font-weight: 800;
        letter-spacing: -0.025em;
      }
      @media (max-width: 600px) { h1 { font-size: 36px; } }
      .lead {
        font-size: 17px;
        color: var(--fg-dim);
        margin: 0 auto 0;
        max-width: 56ch;
        line-height: 1.65;
      }
      /* ── Billing toggle ── */
      .billing-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        margin: 40px auto 36px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        width: fit-content;
        padding: 3px;
      }
      .billing-toggle button {
        padding: 8px 20px;
        border: none;
        background: transparent;
        color: var(--fg-dim);
        font-size: 14px;
        font-weight: 600;
        border-radius: 6px;
        cursor: pointer;
        transition: background 0.12s, color 0.12s;
        position: relative;
      }
      .billing-toggle button.active {
        background: var(--accent);
        color: #fff;
      }
      .billing-toggle button .save-badge {
        position: absolute;
        top: -8px; right: -6px;
        background: #2a6b44;
        color: #7effc8;
        font-size: 9px;
        font-weight: 700;
        padding: 2px 5px;
        border-radius: 4px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      /* ── Tier grid ── */
      .tiers {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
        margin-bottom: 40px;
      }
      @media (max-width: 760px) {
        .tiers { grid-template-columns: 1fr; }
      }
      .tier-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 28px 24px 24px;
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .tier-card.highlighted {
        border-color: var(--accent);
        position: relative;
      }
      .tier-card.highlighted::before {
        content: 'Most popular';
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--accent);
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 3px 12px;
        border-radius: 100px;
        white-space: nowrap;
      }
      .tier-card.muted {
        opacity: 0.85;
      }
      .tier-name {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
      }
      .tier-price {
        display: flex;
        align-items: baseline;
        gap: 6px;
      }
      .price-amount {
        font-size: 40px;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1;
      }
      .price-unit {
        font-size: 15px;
        color: var(--fg-dim);
      }
      .price-note {
        font-size: 12px;
        color: var(--fg-dim);
        margin: 6px 0 0;
      }
      .tier-cta {
        display: inline-block;
        padding: 12px 20px;
        background: var(--accent);
        color: #fff;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
        transition: background 0.15s;
        text-align: center;
      }
      .tier-cta:hover { background: var(--accent-dark); }
      .tier-cta.outline {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--fg-dim);
      }
      .tier-cta.outline:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: transparent;
      }
      .tier-cta.ghost {
        background: transparent;
        border: 1px solid rgba(27,182,115,0.4);
        color: var(--accent);
      }
      .tier-cta.ghost:hover { background: var(--accent); color: #fff; }
      .tier-features {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 9px;
        font-size: 14px;
      }
      .tier-features li {
        color: var(--fg-dim);
        padding-left: 18px;
        position: relative;
        line-height: 1.45;
      }
      .tier-features li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--accent);
        font-weight: 700;
        font-size: 12px;
        top: 1px;
      }
      .tier-features li.dim {
        opacity: 0.55;
      }
      .coming-badge {
        display: inline-block;
        font-size: 9px;
        font-weight: 700;
        padding: 1px 5px;
        border-radius: 3px;
        background: rgba(27,182,115,0.12);
        color: var(--accent);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        vertical-align: middle;
        margin-left: 4px;
      }
      /* ── Free tier panel (above the grid) ── */
      .free-panel {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 24px 26px;
        margin-bottom: 20px;
      }
      .free-panel-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--fg);
        margin: 0 0 12px;
      }
      .free-panel-title span {
        color: var(--accent);
      }
      .free-groups {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 24px;
        font-size: 13px;
        color: var(--fg-dim);
      }
      .free-group { display: flex; align-items: center; gap: 6px; }
      .free-group::before { content: '✓'; color: var(--accent); font-weight: 700; }
      /* ── Privacy note ── */
      .privacy-note {
        text-align: center;
        font-size: 13px;
        color: var(--fg-dim);
        margin: 0 0 40px;
        padding: 14px 20px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
      }
      /* ── Enterprise section ── */
      .enterprise-cta {
        margin: 40px 0 36px;
        padding: 32px 32px 28px;
        background: linear-gradient(135deg, #121d16 0%, #18211c 100%);
        border: 1px solid rgba(27,182,115,0.3);
        border-radius: 16px;
        position: relative;
        overflow: hidden;
      }
      .enterprise-cta::after {
        content: '';
        position: absolute;
        top: -80px; right: -80px;
        width: 240px; height: 240px;
        background: radial-gradient(circle, rgba(27,182,115,0.06) 0%, transparent 70%);
        pointer-events: none;
      }
      .enterprise-eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 10px;
      }
      .enterprise-h2 {
        font-size: 22px;
        font-weight: 800;
        line-height: 1.25;
        margin: 0 0 12px;
        color: var(--fg);
      }
      .enterprise-desc {
        font-size: 15px;
        color: var(--fg-dim);
        margin: 0 0 22px;
        max-width: 56ch;
        line-height: 1.6;
      }
      .enterprise-features {
        list-style: none;
        padding: 0;
        margin: 0 0 26px;
        display: grid;
        gap: 9px;
      }
      .enterprise-features li {
        font-size: 14px;
        color: var(--fg-dim);
        padding-left: 22px;
        position: relative;
      }
      .enterprise-features li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: var(--accent);
        font-weight: 700;
      }
      .enterprise-btn {
        display: inline-block;
        padding: 12px 22px;
        border: 1px solid var(--accent);
        border-radius: 8px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 600;
        font-size: 15px;
        transition: background 0.15s, color 0.15s;
      }
      .enterprise-btn:hover { background: var(--accent); color: #fff; }
      /* ── FAQ ── */
      .faq { margin: 36px 0; }
      .faq h2 { font-size: 22px; margin: 0 0 16px; }
      .faq details {
        padding: 12px 16px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 8px;
        margin-bottom: 8px;
      }
      .faq summary { cursor: pointer; font-weight: 600; }
      .faq details[open] summary { margin-bottom: 8px; }
      .faq details p { margin: 4px 0; color: var(--fg-dim); font-size: 14px; }
      .faq a, .lead a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
      .faq a:hover, .lead a:hover { color: #fff; }
      .footer-note {
        margin-top: 48px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        color: var(--fg-dim);
        font-size: 13px;
      }
      .footer-note a { color: var(--accent); }
      code { background: rgba(255,255,255,0.06); padding: 1px 5px; border-radius: 3px; font-size: 13px; }
    </style>
  </head>
  <body>
    <Nav />
    <div class="page-content">

      <div class="hero">
        <span class="eyebrow-pill">Upgrade</span>
        <h1>Memory that stays yours.</h1>
        <p class="lead">
          Every plan runs entirely on your machine. No data leaves your device.
          The license token is the only thing that touches the network.
        </p>
      </div>

      <!-- Persona bar -->
      <PersonaBar compact />

      <!-- Billing toggle -->
      <div class="billing-toggle">
        <button class="active" data-billing="monthly" onclick="setBilling('monthly')">Monthly</button>
        <button data-billing="annual" onclick="setBilling('annual')">
          Annual
          <span class="save-badge">2 months free</span>
        </button>
      </div>

      <!-- Free tier always-included panel -->
      <div class="free-panel">
        <p class="free-panel-title">Always free — <span>no credit card, no trial</span></p>
        <div class="free-groups">
          <span class="free-group">All 31 deterministic MCP tools</span>
          <span class="free-group">recall, remember, forget, edit</span>
          <span class="free-group">Up to 3 engrams</span>
          <span class="free-group">All connectors (daily cadence)</span>
          <span class="free-group">Sensitivity tiers &amp; consent gating</span>
          <span class="free-group">Memory Integrity Workbench (in-app review)</span>
          <span class="free-group">Temporal decay &amp; local embeddings</span>
          <span class="free-group">Use &amp; import skill packs (.gsk)</span>
          <span class="free-group">FSL source-available</span>
        </div>
      </div>

      <!-- Three-tier pricing grid -->
      <div class="tiers">

        <!-- Pro -->
        <div class="tier-card highlighted" style="grid-column: 1 / 2">
          <div>
            <div class="tier-name">Pro</div>
            <div class="tier-price">
              <span class="price-amount" data-monthly="$10" data-annual="$99">$10</span>
              <span class="price-unit" data-monthly="/ month" data-annual="/ year">&nbsp;/ month</span>
            </div>
            <p class="price-note" data-monthly="Cancel anytime." data-annual="$8.25 / mo effective · 2 months free.">Cancel anytime.</p>
          </div>
          <a class="tier-cta" id="pro-cta" href={`/upgrade/checkout?plan=monthly${emailParam}`}>
            Start subscription →
          </a>
          <ul class="tier-features">
            <li>Everything in Free</li>
            <li>Unlimited engrams</li>
            <li>Connector cadence — any interval, not just daily</li>
            <li><strong>Skills authoring</strong> — train, rollback, export <code>.gsk</code>, vitality scoring</li>
            <li><strong>Foresight</strong> — local LLM via Ollama: develop, predict, insights, llm_query, llm_distill</li>
            <li><strong>GNN</strong> — neural-network edge predictions, graph exploration overlay</li>
            <li>audit_memory + duplicate_pairs</li>
            <li><strong>MCP tool control</strong> — choose which tools AI clients can call (Recall-only, Remember-only, or custom)</li>
            <li class="dim">Multi-device sync — full offline-capable cortex replication across your own devices <span class="coming-badge">soon</span></li>
          </ul>
        </div>

        <!-- Teams -->
        <div class="tier-card muted" style="grid-column: 2 / 3">
          <div>
            <div class="tier-name">Teams <span class="coming-badge">early access</span></div>
            <div class="tier-price">
              <span class="price-amount" data-monthly="$25" data-annual="$249">$25</span>
              <span class="price-unit" data-monthly="/ month" data-annual="/ year">&nbsp;/ month</span>
            </div>
            <p class="price-note" data-monthly="Per person · no minimum." data-annual="Per person · $20.75 / mo effective · 2 months free.">Per person · no minimum.</p>
          </div>
          <a class="tier-cta ghost" href="mailto:enterprise@graphnosis.com">
            Get early access →
          </a>
          <ul class="tier-features">
            <li>Everything in Pro</li>
            <li><strong>Shared engrams</strong> — scoped bearer tokens (viewer / editor) per engram; teammates connect their own AI client with zero access outside their scope</li>
            <li><strong>Team Admin panel</strong> — live per-token active session counts</li>
            <li><strong>Engram packs</strong> — export / import signed, encrypted <code>.gez</code> bundles for offline or cross-team sharing</li>
            <li>Time-travel recall — graph state at any past date <span class="coming-badge">soon</span></li>
            <li>Spaced repetition / resurface scheduler <span class="coming-badge">soon</span></li>
            <li>Custom MCP tool composer <span class="coming-badge">soon</span></li>
            <li>Outgoing webhook triggers <span class="coming-badge">soon</span></li>
          </ul>
        </div>

        <!-- Enterprise -->
        <div class="tier-card" style="grid-column: 3 / 4">
          <div>
            <div class="tier-name">Enterprise</div>
            <div class="tier-price">
              <span class="price-amount" style="font-size:24px; padding-top: 8px;">Custom</span>
            </div>
            <p class="price-note">Annual contracts · negotiated.</p>
          </div>
          <a class="tier-cta ghost" href="mailto:enterprise@graphnosis.com">
            Contact us →
          </a>
          <ul class="tier-features">
            <li>Everything in Teams</li>
            <li>Air-gapped / on-premises deployment</li>
            <li><strong>SSO token provisioning</strong> — <code>/admin/provision</code> for MDM / onboarding pipelines</li>
            <li><strong>Audit log export</strong> — <code>/admin/audit</code> JSON &amp; CSV op-log for SIEM ingestion</li>
            <li>Compliance controls, RBAC, role-scoped engrams</li>
            <li>HIPAA BAA, GDPR DPA, SOC 2</li>
            <li>Dedicated onboarding + SLA</li>
          </ul>
        </div>

      </div>

      <p class="privacy-note">
        Pro doesn't ship your data anywhere. Engrams stay on your device, encrypted with your passphrase.
        The license token is the only thing that touches the network — and it's signed and locally-verifiable, no live phone-home.
      </p>

      <div class="enterprise-cta">
        <p class="enterprise-eyebrow">Enterprise &amp; Regulated Deployments</p>
        <h2 class="enterprise-h2">Built for environments where data doesn't leave the building.</h2>
        <p class="enterprise-desc">
          Legal, healthcare, defense, fintech, public sector. Air-gapped deployment,
          compliance controls, SSO, and SLA — scoped to your requirements. Let's talk.
        </p>
        <div style="display:flex; align-items:center; gap:20px; flex-wrap:wrap;">
          <a class="enterprise-btn" href="mailto:enterprise@graphnosis.com">
            Contact for enterprise access →
          </a>
          <a href="/guides/enterprise-faq/" style="font-size:14px; color:var(--fg-dim); text-decoration:underline; text-underline-offset:2px;">
            Read the Enterprise IT FAQ →
          </a>
        </div>
      </div>

      <div class="faq">
        <h2>Questions</h2>

        <details>
          <summary>How does the license actually work?</summary>
          <p>
            After checkout we email you a one-time magic link. Click it and
            Graphnosis turns Pro on automatically via a <code>graphnosis://</code>
            deep link. If that doesn't work (no Graphnosis on this device, or
            the scheme isn't registered yet), you can paste the token into
            Graphnosis → Settings → License.
          </p>
          <p>
            The token is signed by our license server using an Ed25519
            keypair. Graphnosis verifies it locally — no network call needed
            at runtime.
          </p>
        </details>

        <details>
          <summary>What's the difference between the annual and monthly plans?</summary>
          <p>
            Same features, different billing. Annual gives you 2 months free (Pro: $99/yr vs $120/yr equivalent; Teams: $249/yr vs $300/yr equivalent).
            You can switch between monthly and annual through the Stripe customer portal at any time.
          </p>
        </details>

        <details>
          <summary>Can I install Graphnosis Pro on multiple devices?</summary>
          <p>
            Yes. The same token works on every device tied to your email.
            Hit "Refresh from server" in the license panel on a new device
            and we'll re-email you the token.
          </p>
        </details>

        <details>
          <summary>What happens if I cancel?</summary>
          <p>
            Your token expires at the end of the current billing period.
            Pro features stop working, but every Pro-trained skill, every
            GNN edge, every retrain config you produced stays in your
            cortex — they just become read-only. Re-subscribe and they
            light back up.
          </p>
        </details>

        <details>
          <summary>Is there a free trial?</summary>
          <p>
            Not currently. The free source-only compile path lets you
            experience the Skills workflow end-to-end — structure from your
            authored text, without the Pro LLM rewrite. If that's not enough, Pro is one click away.
          </p>
        </details>

        <details>
          <summary>What does the 3-engram Free limit cover?</summary>
          <p>
            Up to 3 user-created engrams. The built-in Graphnosis Docs and Skill Demos
            engrams don't count against this — they're system engrams. Pro removes
            the limit entirely.
          </p>
        </details>

        <details>
          <summary>What is Teams early access?</summary>
          <p>
            Teams early access includes shared engrams (scoped bearer tokens with viewer / editor roles per engram),
            the Team Admin panel, and signed encrypted engram packs (<code>.gez</code>) for offline sharing — all shipping now.
            Additional Teams features (time-travel recall, spaced repetition, outgoing webhooks) continue to roll out.
            Early access customers are the first to try each one. Email
            <a href="mailto:enterprise@graphnosis.com">enterprise@graphnosis.com</a>
            to get on the list.
          </p>
        </details>

        <details>
          <summary>Do you offer enterprise plans?</summary>
          <p>
            Yes — see the Enterprise &amp; Regulated Deployments section above,
            and our <a href="/guides/enterprise-faq/">Enterprise IT FAQ</a> for
            security, deployment, and compliance details.
            Compliance Mode, RBAC, SSO, HIPAA BAA, and air-gapped deployment are
            on the roadmap. Reach out at
            <a href="mailto:enterprise@graphnosis.com">enterprise@graphnosis.com</a>
            for early access or custom requirements.
          </p>
          <p>
            For a detailed technical reference covering installation, security, data handling,
            and compliance mapping (GDPR, HIPAA, FedRAMP, IEC 62443), see the
            <a href="/guides/enterprise-faq/">Enterprise IT FAQ</a>.
          </p>
        </details>
      </div>

      <p class="footer-note">
        Already subscribed but missing your token?
        <a href="/api/auth/magic-link">Re-send the magic link</a> or open
        Graphnosis → Settings → Pro license → "Refresh from server".
        <br />
        Questions? Email <a href="mailto:support@graphnosis.com">support@graphnosis.com</a>.
      </p>

    </div><!-- /.page-content -->

    <Footer />

    <script>
      // Astro scopes <script> as an ES module — assign to window so inline onclick can reach it.
      window.setBilling = function(mode) {
        document.querySelectorAll('.billing-toggle button').forEach(btn => {
          btn.classList.toggle('active', btn.dataset.billing === mode);
        });
        document.querySelectorAll('[data-monthly]').forEach(el => {
          const val = el.dataset[mode];
          if (val) el.textContent = val;
        });
        const proCta = document.getElementById('pro-cta');
        if (proCta) {
          const emailParam = new URLSearchParams(window.location.search).get('email');
          const ep = emailParam ? `&email=${encodeURIComponent(emailParam)}` : '';
          proCta.href = `/upgrade/checkout?plan=${mode === 'annual' ? 'annual' : 'monthly'}${ep}`;
        }
      };
    </script>
  </body>
</html>
