---
export const prerender = false;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Checkout cancelled</title>
    <style>
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
             max-width: 480px; margin: 8vh auto; padding: 0 24px; color: #1a1a1a; line-height: 1.55; }
      h1 { font-size: 26px; }
      .btn { display: inline-block; padding: 10px 18px; background: #1bb673; color: #fff;
             border-radius: 6px; text-decoration: none; font-weight: 600; }
    </style>
  </head>
  <body>
    <h1>No charges, no worries.</h1>
    <p>You cancelled before paying — nothing on your card. If you change your
       mind, just hit Upgrade again from Graphnosis.</p>
    <p><a class="btn" href="/upgrade">Try again</a></p>
  </body>
</html>
