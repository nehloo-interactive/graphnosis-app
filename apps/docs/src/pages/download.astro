---
/**
 * /download — OS chooser + auto-detect landing page.
 *
 * Linked from every Download button on the site. Shows macOS, Windows and
 * Linux download cards (Linux offers both an AppImage and an Ubuntu/Debian
 * .deb), plus a Linux install guide below the cards. Detects the user's OS
 * on load purely to highlight the matching card — no auto-redirect; the
 * visitor always clicks.
 *
 * The download targets are the /download/{mac,win,linux,linux-deb} redirect
 * routes, all resolved by the Pages Function at functions/download/[platform].ts
 * (NOT public/_redirects — Cloudflare runs Functions first and bypasses
 * _redirects for matched routes). mac + win 302 to the GitHub Releases artifact
 * for the CURRENT release automatically, via the CURRENT_VERSION / DMG_FILENAME /
 * WINDOWS_FILENAME env vars the release workflow sets on every tag.
 *
 * NOTE: Linux .AppImage + .deb are attached to a release by the build-linux
 * workflow (workflow_dispatch, upload_to_release=true) — they're not part of the
 * default release.yml run. A release with no Linux bundle yet 404s on
 * /download/linux until that backfill runs. The install-snippet semver below
 * tracks the app version from tauri.conf.json.
 */
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

// Read the current version from tauri.conf.json at build time. Falls back
// to empty string if the file isn't where we expect — the page still
// renders, just without the "Graphnosis v1.X.Y" pill.
let version = '';
try {
  const conf = JSON.parse(readFileSync(resolve('../../apps/desktop/src-tauri/tauri.conf.json'), 'utf8'));
  version = conf.version ? `v${conf.version}` : '';
} catch { /* docs site built standalone — skip the pill */ }

// Bare semver (no leading "v") for artifact filenames in the Linux install
// snippets — Tauri names its bundles Graphnosis_<semver>_amd64.AppImage etc.
// Falls back to a literal placeholder so the snippets still read sensibly
// if the version couldn't be resolved at build time.
const semver = version ? version.replace(/^v/, '') : '1.x.y';
---

<Layout
  title="Download Graphnosis — macOS, Windows & Linux"
  description="Download the free Graphnosis app for macOS, Windows, or Linux (AppImage & Ubuntu/Debian .deb). Local, encrypted, deterministic memory for your AI — zero servers, zero data leaves your machine."
>
  <Nav />

  <main class="min-h-screen">

    <!-- Hero -->
    <section class="relative py-20 px-4 sm:px-6 overflow-hidden">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#67e8f9]/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#a78bfa]/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class="max-w-3xl mx-auto text-center relative z-10">
        {version && (
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#2a2a3d] bg-[#1c1c27] text-sm font-mono text-[#c4c6d6] mb-6">
            <span class="text-[#67e8f9] font-semibold">Latest:</span> Graphnosis {version}
          </div>
        )}
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.1] mb-5">
          Download Graphnosis
        </h1>
        <p class="text-lg text-[#c4c6d6] max-w-2xl mx-auto leading-relaxed">
          Free, local-first memory for your AI. Encrypted at rest, runs entirely on your device,
          works offline. Pick your operating system.
        </p>
        <p
          id="download-detect-note"
          class="text-sm font-mono text-[#67e8f9] mt-4 hidden"
        >
          Detected your OS — your card is highlighted below.
        </p>
      </div>
    </section>

    <!-- OS cards -->
    <section class="pb-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- macOS -->
        <article
          id="download-card-mac"
          class="download-os-card bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-7 flex flex-col gap-5 transition-all"
          data-os="mac"
        >
          <div class="w-14 h-14 rounded-xl bg-white/[0.06] flex items-center justify-center" aria-hidden="true">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M14.94 5.19A4.38 4.38 0 0 0 16 2a4.44 4.44 0 0 0-3 1.52 4.17 4.17 0 0 0-1 3.09 3.69 3.69 0 0 0 2.94-1.42zm2.52 7.44a4.51 4.51 0 0 1 2.16-3.81 4.66 4.66 0 0 0-3.66-2c-1.56-.16-3 .91-3.83.91s-2-.89-3.3-.87a4.92 4.92 0 0 0-4.14 2.53C2.91 12.87 4.24 17.88 6 20.47c.8 1.21 1.8 2.58 3.12 2.53s1.75-.82 3.28-.82 2 .82 3.3.79 2.22-1.24 3.06-2.45a11 11 0 0 0 1.38-2.85 4.41 4.41 0 0 1-2.68-4.04z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-black text-white mb-1">macOS</h2>
            <p class="text-sm text-[#9a9db8]">Apple Silicon · macOS 13 Ventura or later</p>
          </div>
          <ul class="flex flex-col gap-2 text-sm text-[#b0b3c6] flex-1">
            <li class="flex items-start gap-2"><span class="text-[#67e8f9] mt-0.5">✓</span><span>Signed &amp; notarized <code class="text-[#67e8f9] font-mono">.dmg</code></span></li>
            <li class="flex items-start gap-2"><span class="text-[#67e8f9] mt-0.5">✓</span><span>Universal binary (Apple Silicon native)</span></li>
            <li class="flex items-start gap-2"><span class="text-[#67e8f9] mt-0.5">✓</span><span>Touch ID + Keychain integration</span></li>
          </ul>
          <a
            href="/download/mac"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-[#67e8f9] hover:bg-[#4dd6e8] text-[#13131a] font-bold text-base transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
            </svg>
            Download for macOS{version ? ` ${version}` : ''}
          </a>
          <p class="text-center text-[11px] text-[#71717a] leading-none">
            <a href="/legal/terms-of-use" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">Terms</a>
            &nbsp;·&nbsp;
            <a href="/legal/privacy-policy" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">Privacy</a>
          </p>
        </article>

        <!-- Windows -->
        <article
          id="download-card-win"
          class="download-os-card bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-7 flex flex-col gap-5 transition-all"
          data-os="win"
        >
          <div class="w-14 h-14 rounded-xl bg-white/[0.06] flex items-center justify-center" aria-hidden="true">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 12V6.75l7-1.24v6.49H3zm8 0V5.29L21 3.5V12H11zM3 13h7v6.49l-7-1.23V13zm8 0h10v8.5L11 19.71V13z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-black text-white mb-1">Windows</h2>
            <p class="text-sm text-[#9a9db8]">x64 · Windows 10 or later</p>
          </div>
          <ul class="flex flex-col gap-2 text-sm text-[#b0b3c6] flex-1">
            <li class="flex items-start gap-2"><span class="text-[#60a5fa] mt-0.5">✓</span><span>NSIS installer (<code class="text-[#60a5fa] font-mono">.exe</code>)</span></li>
            <li class="flex items-start gap-2"><span class="text-[#60a5fa] mt-0.5">✓</span><span>Code-signed by Nehloo Interactive LLC</span></li>
            <li class="flex items-start gap-2"><span class="text-[#60a5fa] mt-0.5">✓</span><span>Windows Hello integration</span></li>
          </ul>
          <a
            href="/download/win"
            class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-[#60a5fa] hover:bg-[#3b82f6] text-[#13131a] font-bold text-base transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
            </svg>
            Download for Windows{version ? ` ${version}` : ''}
          </a>
          <p class="text-center text-[11px] text-[#71717a] leading-none">
            <a href="/legal/terms-of-use" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">Terms</a>
            &nbsp;·&nbsp;
            <a href="/legal/privacy-policy" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">Privacy</a>
          </p>
        </article>

        <!-- Linux -->
        <article
          id="download-card-linux"
          class="download-os-card bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-7 flex flex-col gap-5"
          data-os="linux"
        >
          <div class="w-14 h-14 rounded-xl bg-white/[0.06] flex items-center justify-center" aria-hidden="true">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="3" width="20" height="18" rx="2"/>
              <path d="M8 9l4 4-4 4M14 17h3"/>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-black text-white mb-1">Linux</h2>
            <p class="text-sm text-[#9a9db8]">x86_64 · Ubuntu, Debian, Fedora, Arch</p>
          </div>
          <ul class="flex flex-col gap-2 text-sm text-[#b0b3c6] flex-1">
            <li class="flex items-start gap-2"><span class="text-[#a78bfa] mt-0.5">✓</span><span><code class="text-[#a78bfa] font-mono">.AppImage</code> — runs on any distro</span></li>
            <li class="flex items-start gap-2"><span class="text-[#a78bfa] mt-0.5">✓</span><span><code class="text-[#a78bfa] font-mono">.deb</code> — Debian / Ubuntu, menu entry + apt updates</span></li>
            <li class="flex items-start gap-2"><span class="text-[#a78bfa] mt-0.5">✓</span><span>Same encrypted sidecar &amp; offline-first runtime</span></li>
          </ul>
          <div class="flex flex-col gap-2">
            <a
              href="/download/linux"
              class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-full bg-[#a78bfa] hover:bg-[#9069f0] text-[#13131a] font-bold text-base transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
              </svg>
              Download for Linux{version ? ` ${version}` : ''}
            </a>
            <a
              href="/download/linux-deb"
              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full border border-[#a78bfa]/40 hover:border-[#a78bfa] bg-[#a78bfa]/10 hover:bg-[#a78bfa]/20 text-[#c4b5fd] font-semibold text-sm transition-colors"
            >
              Ubuntu / Debian <code class="font-mono">.deb</code>
            </a>
          </div>
          <p class="text-center text-[11px] text-[#71717a] leading-none">
            <a href="#linux-install" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">Install guide</a>
            &nbsp;·&nbsp;
            <a href="/legal/terms-of-use" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">Terms</a>
            &nbsp;·&nbsp;
            <a href="/legal/privacy-policy" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">Privacy</a>
          </p>
        </article>

      </div>
    </section>

    <!-- Linux install guide -->
    <section id="linux-install" class="pb-16 px-4 sm:px-6 scroll-mt-24">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-black text-white mb-2">Installing on Linux</h2>
        <p class="text-[#c4c6d6] mb-8 leading-relaxed">
          Graphnosis ships two Linux builds for <code class="text-[#a78bfa] font-mono">x86_64</code>.
          The <strong class="text-white">AppImage</strong> runs on any distribution with no install step;
          the <strong class="text-white">.deb</strong> integrates with Debian / Ubuntu (app-menu entry and
          <code class="text-[#a78bfa] font-mono">apt</code> updates). Both bundle the same encrypted,
          offline-first sidecar.
        </p>

        <!-- AppImage -->
        <div class="bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-6 mb-6">
          <h3 class="text-lg font-bold text-white mb-1 flex items-center gap-2">
            <code class="text-[#a78bfa] font-mono text-base">.AppImage</code>
            <span class="text-sm font-normal text-[#9a9db8]">— any distribution</span>
          </h3>
          <p class="text-sm text-[#b0b3c6] mb-4 leading-relaxed">
            Download, mark it executable, and run it — no root, no install. On Ubuntu 22.04+ you may
            need FUSE: <code class="text-[#a78bfa] font-mono">sudo apt install libfuse2</code>.
          </p>
          <pre class="install-snippet"><code># Make it executable and launch
chmod +x Graphnosis_{semver}_amd64.AppImage
./Graphnosis_{semver}_amd64.AppImage</code></pre>
        </div>

        <!-- Ubuntu / Debian .deb -->
        <div class="bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-6">
          <h3 class="text-lg font-bold text-white mb-1 flex items-center gap-2">
            <code class="text-[#a78bfa] font-mono text-base">.deb</code>
            <span class="text-sm font-normal text-[#9a9db8]">— Ubuntu / Debian</span>
          </h3>
          <p class="text-sm text-[#b0b3c6] mb-4 leading-relaxed">
            Installs to <code class="text-[#a78bfa] font-mono">/usr/bin</code> with a desktop entry.
            Using <code class="text-[#a78bfa] font-mono">apt</code> pulls in any missing dependencies
            automatically.
          </p>
          <pre class="install-snippet"><code># Recommended — resolves dependencies
sudo apt install ./Graphnosis_{semver}_amd64.deb

# Or with dpkg, then fix any missing deps
sudo dpkg -i Graphnosis_{semver}_amd64.deb
sudo apt-get install -f</code></pre>
          <p class="text-xs text-[#71717a] mt-4 leading-relaxed">
            Launch from your app menu, or run <code class="text-[#9a9db8] font-mono">graphnosis</code>
            from a terminal. Update later with <code class="text-[#9a9db8] font-mono">sudo apt install ./Graphnosis_…_amd64.deb</code>
            or by reinstalling a newer <code class="text-[#9a9db8] font-mono">.deb</code>.
          </p>
        </div>
      </div>
    </section>

    <!-- Footnote -->
    <section class="pb-24 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-sm text-[#71717a]">
          Source available under the FSL license &middot;
          <a href="https://github.com/nehloo-interactive/graphnosis-app" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">
            View on GitHub
          </a>
          &middot; Free forever &middot; No account required
        </p>
        <p class="text-sm text-[#71717a] mt-3">
          Running a personal server? See the
          <a href="https://docs.graphnosis.com/getting-started/mobile/" class="text-[#9a9db8] hover:text-[#c4c6d6] transition-colors underline decoration-[#71717a]/50">
            self-host &amp; phone guide &rarr;
          </a>
        </p>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* Highlight ring for the OS card matching the user's detected OS.
     Pure CSS — JS only adds the .is-detected class. */
  .download-os-card.is-detected {
    border-color: #67e8f9;
    box-shadow: 0 0 0 1px #67e8f933, 0 8px 32px -8px #67e8f922;
    transform: translateY(-2px);
  }

  /* Copy-paste install snippets in the Linux guide. Monospace, scrollable
     on narrow viewports, with a subtle border so they read as terminal
     blocks rather than body text. */
  .install-snippet {
    margin: 0;
    padding: 14px 16px;
    border-radius: 10px;
    background: #13131a;
    border: 1px solid #2a2a3d;
    overflow-x: auto;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 13px;
    line-height: 1.6;
    color: #e4e4ef;
    white-space: pre;
  }
  .install-snippet code {
    font-family: inherit;
    color: inherit;
    background: none;
    padding: 0;
  }
</style>

<script is:inline>
  // Detect the user's OS once on load and highlight the matching card.
  // No auto-redirect — the user always sees the cards and clicks. The
  // user-OS hint just helps them spot the right card faster.
  //
  // Detection priority:
  //   1. navigator.userAgentData.platform (modern Chromium / Edge)
  //   2. navigator.platform (legacy + Safari)
  //   3. fallback to navigator.userAgent string match
  (function () {
    function detectOs() {
      try {
        var uaData = (navigator).userAgentData;
        if (uaData && uaData.platform) {
          var p = uaData.platform.toLowerCase();
          if (p.indexOf('mac') !== -1) return 'mac';
          if (p.indexOf('win') !== -1) return 'win';
          if (p.indexOf('linux') !== -1) return 'linux';
        }
      } catch (_) { /* userAgentData not available */ }
      var plat = (navigator.platform || '').toLowerCase();
      if (plat.indexOf('mac') !== -1) return 'mac';
      if (plat.indexOf('win') !== -1) return 'win';
      if (plat.indexOf('linux') !== -1) return 'linux';
      var ua = (navigator.userAgent || '').toLowerCase();
      if (ua.indexOf('mac') !== -1) return 'mac';
      if (ua.indexOf('win') !== -1) return 'win';
      if (ua.indexOf('linux') !== -1) return 'linux';
      return null;
    }
    var os = detectOs();
    if (!os) return;
    var card = document.getElementById('download-card-' + os);
    if (card) card.classList.add('is-detected');
    var note = document.getElementById('download-detect-note');
    if (note) note.classList.remove('hidden');
  })();
</script>
</Layout>
