<style>
  /* Highlight ring for the OS card matching the user's detected OS.
     Pure CSS — JS only adds the .is-detected class. */
  .download-os-card.is-detected {
    border-color: #67e8f9;
    box-shadow: 0 0 0 1px #67e8f933, 0 8px 32px -8px #67e8f922;
    transform: translateY(-2px);
  }


</style>

<script is:inline>
  // Detect the user's OS once on load and highlight the matching card.
  // No auto-redirect — the user always sees the cards and clicks. The
  // user-OS hint just helps them spot the right card faster.
  //
  // Detection priority:
  //   1. navigator.userAgentData.platform (modern Chromium / Edge)
  //   2. navigator.platform (legacy + Safari)
  //   3. fallback to navigator.userAgent string match
  (function () {
    function detectOs() {
      try {
        var uaData = (navigator).userAgentData;
        if (uaData && uaData.platform) {
          var p = uaData.platform.toLowerCase();
          if (p.indexOf('mac') !== -1) return 'mac';
          if (p.indexOf('win') !== -1) return 'win';
          if (p.indexOf('linux') !== -1) return 'linux';
        }
      } catch (_) { /* userAgentData not available */ }
      var plat = (navigator.platform || '').toLowerCase();
      if (plat.indexOf('mac') !== -1) return 'mac';
      if (plat.indexOf('win') !== -1) return 'win';
      if (plat.indexOf('linux') !== -1) return 'linux';
      var ua = (navigator.userAgent || '').toLowerCase();
      if (ua.indexOf('mac') !== -1) return 'mac';
      if (ua.indexOf('win') !== -1) return 'win';
      if (ua.indexOf('linux') !== -1) return 'linux';
      return null;
    }
    var os = detectOs();
    if (!os) return;
    var card = document.getElementById('download-card-' + os);
    if (card) card.classList.add('is-detected');
    var note = document.getElementById('download-detect-note');
    if (note) note.classList.remove('hidden');
  })();
</script>
</Layout>
