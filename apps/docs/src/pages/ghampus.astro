---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PersonaBar from '../components/PersonaBar.astro';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

let version = '';
try {
  const conf = JSON.parse(readFileSync(resolve('../../apps/desktop/src-tauri/tauri.conf.json'), 'utf8'));
  version = conf.version ? `v${conf.version}` : '';
} catch { /* standalone build */ }
---

<Layout
  title="Ghampus Hush — Your confidential AI. Already on it. | Graphnosis"
  description="Your confidential AI teammate — on-device memory, consent-gated recall, proactive skill walks. Your secrets stay on your machine. Free, Pro, Teams, Enterprise — all have access."
>
  <Nav />

  <main>

    <!-- Hero -->
    <section class="pt-24 pb-12 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto text-center">
        <PersonaBar />

        <!-- Graphnosis logo anchors the hero. Ghampus chip below reads
             as a sub-product mark of the parent brand. -->
        <img src="/graphnosis-logo-transparent-bg.png" alt="" aria-hidden="true" class="w-16 h-16 mx-auto mb-5 opacity-95" />

        <div class="inline-flex items-center justify-center mb-6 px-6 py-2 rounded-full border border-cyan-400/40 bg-cyan-400/8 text-2xl font-black tracking-wide text-cyan-300">
          Ghampus Hush
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight">
          Your confidential AI.
          <span class="block bg-clip-text text-transparent mt-2" style="background-image: linear-gradient(135deg, #10b981 0%, #06b6d4 100%);">Already on it.</span>
        </h1>
        <p class="text-xl text-[#a5f3fc] leading-relaxed max-w-3xl mx-auto font-medium mb-4">
          Your secrets stay on your machine. Ghampus watches your memory grow, walks your playbook, and checks in before you had to ask.
        </p>
        <p class="text-lg text-[#c4c6d6] leading-relaxed max-w-3xl mx-auto">
          Ghampus Hush is the in-app face of Graphnosis — the seahorse who does for your second brain what your hippocampus does for your first. On-device memory, consent-gated recall, proactive skill walks. Same cortex and MCP tools as Claude Desktop, Cursor, and Copilot — but everything runs locally unless you choose otherwise. Enterprise-friendly when IT needs locks and audit trails; warm and human when you're just trying to get work done. Free, Pro, Teams, Enterprise — all have access. Higher tiers add more discipline.
        </p>
      </div>
    </section>

    <!-- Three pillars -->
    <section class="py-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6">
        <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
          <div class="text-3xl mb-3">🤖</div>
          <h3 class="text-xl font-bold text-white mb-3">Surfaces what matters first</h3>
          <p class="text-[#c4c6d6] text-sm leading-relaxed">
            "While you were away" lists overnight activity — connector pulls, AI client saves, edits from collaborators on shared engrams. "Picking up where we left off" surfaces what was saved in prior sessions. Suggests the right skill SOP the moment it matches the work in front of you. Your session memory IS your real memory.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
          <div class="text-3xl mb-3">🎯</div>
          <h3 class="text-xl font-bold text-white mb-3">Pick the right model per step</h3>
          <p class="text-[#c4c6d6] text-sm leading-relaxed">
            Skills declare what each step needs — <code class="text-cyan-300">reasoning</code>, <code class="text-cyan-300">structured-output</code>, <code class="text-cyan-300">cited</code>, <code class="text-cyan-300">code</code>, <code class="text-cyan-300">vision</code>. The router picks the cheapest available model that meets the constraints. Cost preview before every paid call.
          </p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.02] p-6">
          <div class="text-3xl mb-3">📎</div>
          <h3 class="text-xl font-bold text-white mb-3">Link files without ingesting</h3>
          <p class="text-[#c4c6d6] text-sm leading-relaxed">
            Attach PDFs, images, spreadsheets, OneNote URIs, anything — the file stays where it is. Recall surfaces them as "Linked files" cards; one click opens the original in its native app. SHA-256 hashes survive file moves.
          </p>
        </div>
      </div>
    </section>

    <!-- Free tier honesty -->
    <section class="py-16 px-4 sm:px-6 bg-white/[0.02]">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-6 text-center">Free works. Pro adds capability, not access.</h2>
        <p class="text-[#c4c6d6] text-lg leading-relaxed mb-8 text-center">
          We didn't paywall Ghampus Hush. Every plan can use it; what you pay for unlocks more capability inside it.
        </p>

        <div class="grid md:grid-cols-2 gap-4">
          <div class="rounded-xl border border-white/10 bg-black/30 p-5">
            <h4 class="text-lg font-bold text-white mb-2">Free</h4>
            <ul class="text-[#c4c6d6] text-sm space-y-1.5">
              <li>✓ Full Ghampus Hush surface</li>
              <li>✓ Same MCP tools as Free external clients</li>
              <li>✓ Local model routing (Ollama)</li>
              <li>✓ File attachments</li>
              <li>✓ Savings tracker</li>
              <li>✓ 1 active share to a collaborator</li>
            </ul>
          </div>
          <div class="rounded-xl border border-emerald-400/30 bg-emerald-400/5 p-5">
            <h4 class="text-lg font-bold text-white mb-2">Pro adds</h4>
            <ul class="text-[#c4c6d6] text-sm space-y-1.5">
              <li>✓ Foresight (`develop` / `predict` / `insights` / `llm_query`)</li>
              <li>✓ Auto-training skills from conversations</li>
              <li>✓ GNN-predicted relationships</li>
              <li>✓ Structured visual extraction</li>
              <li>✓ Unlimited shares</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Privacy + IT controls -->
    <section class="py-16 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-6 text-center">Built for the work you can't send to a cloud.</h2>
        <div class="grid md:grid-cols-2 gap-6 mt-8">
          <div class="rounded-2xl border border-violet-400/30 bg-violet-400/5 p-6">
            <h3 class="text-xl font-bold text-white mb-3">Sensitive engrams stay local</h3>
            <p class="text-[#c4c6d6] text-sm leading-relaxed">
              Steps that touch a sensitive engram are hard-locked to local-only routing. No remote provider sees a token of them. Enforced in the planner, audited on every call. There's no flag to disable this — the gate is architectural.
            </p>
          </div>
          <div class="rounded-2xl border border-violet-400/30 bg-violet-400/5 p-6">
            <h3 class="text-xl font-bold text-white mb-3">IT admin policy</h3>
            <p class="text-[#c4c6d6] text-sm leading-relaxed">
              Disable providers organization-wide for compliance. Pin negotiated rates per-provider or per-model — individual users can't edit admin-enforced entries. Bedrock-only postures, Azure-credit pools, "no public APIs for HR data" — all expressible as policy.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Download CTA -->
    <section class="py-20 px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-6">Available now in {version || 'v1.19.0'}.</h2>
        <p class="text-[#c4c6d6] text-lg leading-relaxed mb-8">
          Open the app, look at the top of the left rail. Ghampus Hush is the default landing tab for new users. Existing users keep landing on whichever view they were on — switch the default in Settings → Preferences whenever.
        </p>
        <a href="/download/" class="inline-flex items-center px-6 py-3 rounded-lg font-semibold text-white bg-gradient-to-r from-emerald-500 to-cyan-500 hover:from-emerald-400 hover:to-cyan-400 transition-colors">
          Download Graphnosis {version || 'v1.19.0'} →
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
