<Layout
  title="Graphnosis Starter Kits — Pre-built memory for your profession"
  description="Starter kits for Graphnosis: named recall patterns, engram schemas, and workflow guides pre-configured for your profession. Zero data. No servers."
>
  <Nav />
  <main>

    <!-- Header -->
    <section class="py-20 px-4 sm:px-6 text-center">
      <div class="max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[#2a2a3d] bg-[#1c1c27] text-[#a78bfa] text-xs font-semibold tracking-widest uppercase mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[#a78bfa]"></span>
          Starter Kits
        </div>
        <h1 class="text-4xl sm:text-5xl font-black mb-4 leading-tight">
          <span class="bg-clip-text text-transparent" style="background-image: linear-gradient(135deg, #67e8f9 0%, #a78bfa 100%);">
            Job Memory Starter Kits
          </span>
        </h1>
        <p class="text-[#c4c6d6] text-lg leading-relaxed mb-3 max-w-2xl mx-auto">
          Start managing your job memory for your profession with a starter kit.
        </p>
        <p class="text-xl font-semibold mb-4 bg-clip-text text-transparent" style="background-image: linear-gradient(90deg, #a78bfa 0%, #67e8f9 100%);">
          Local, private, encrypted, deterministic — auditable.
        </p>
        <p class="text-[#c4c6d6] text-sm mb-8">
          One-time purchase · Yours forever · Works with the free Graphnosis download
        </p>

        <!-- Zero data · zero servers callout -->
        <div class="bg-[#1c1c27] border border-[#2a2a3d] rounded-xl p-5 text-left flex gap-4 items-start max-w-2xl mx-auto">
          <svg class="w-5 h-5 shrink-0 mt-0.5 text-[#67e8f9]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          <div>
            <p class="text-[#f0f0f5] font-semibold text-sm mb-1">These packs contain zero actual data. Graphnosis has zero servers.</p>
            <p class="text-[#c4c6d6] text-sm leading-relaxed">
              A pack is a structure: engram schemas, recall patterns, and connector guides. Your memory is
              built from your own files, on your own device. Nothing is pre-loaded, nothing is shared,
              and no Graphnosis server ever touches it. Every kit is a starting point — fully expandable
              and customizable by you, without limitation, under the free or any tiered plan.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Filter bar -->
    <section id="filter-bar" class="px-4 sm:px-6 pb-8 sticky top-16 z-40 bg-[#13131a]/95 backdrop-blur-md border-b border-[#2a2a3d]">
      <div class="max-w-7xl mx-auto pt-4 flex flex-col sm:flex-row gap-3">
        <!-- Search -->
        <div class="relative shrink-0 sm:w-56">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#52525b]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
          <input
            id="pack-search"
            type="search"
            placeholder="Search packs…"
            class="w-full pl-9 pr-3 py-2 rounded-full bg-[#1c1c27] border border-[#2a2a3d] focus:border-[#67e8f9] focus:outline-none text-[#f0f0f5] placeholder-[#52525b] text-sm transition-colors"
          />
        </div>
        <!-- Compliance nav chip + category chips -->
        <div class="flex flex-wrap gap-2">
          <button
            id="compliance-nav-chip"
            class="compliance-nav-chip px-4 py-2 rounded-full text-sm font-semibold border whitespace-nowrap"
          >
            Compliance Matrix
          </button>
          <button
            id="it-nav-chip"
            class="compliance-nav-chip px-4 py-2 rounded-full text-sm font-semibold border whitespace-nowrap"
          >
            IT Business Case
          </button>
          {categories.map((cat) => (
            <button
              class="category-chip px-4 py-2 rounded-full text-sm font-semibold border whitespace-nowrap"
              data-category={cat.id}
              data-active={cat.id === 'all' ? 'true' : undefined}
            >
              {cat.label}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Pack grid -->
    <section class="py-12 px-4 sm:px-6">
      <div class="max-w-7xl mx-auto">

        <!-- Count -->
        <p id="pack-count" class="text-xs text-[#52525b] font-mono mb-6 scroll-mt-24" style="scroll-margin-top:5rem">{packs.length} packs</p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12" id="pack-grid">
          {packs.map((pack) => {
            const color = catColor[pack.category] ?? '#67e8f9';
            const searchText = [pack.name, pack.tagline, ...pack.skills].join(' ').toLowerCase();
            return (
              <article
                class="pack-card bg-[#1c1c27] border border-[#2a2a3d] rounded-2xl p-8 flex flex-col gap-5 relative"
                data-category={pack.category}
                data-search-text={searchText}
                style={`border-color: ${color}18;`}
              >
                {/* Top-right: two-line MEMORY STUDIO / STARTER KIT label */}
                <div class="absolute top-5 right-5 flex flex-col items-end gap-0.5 select-none">
                  <span class="text-[9px] font-black tracking-widest uppercase leading-none" style={`color: ${color};`}>Memory Studio</span>
                  <span class="text-[9px] font-black tracking-widest uppercase leading-none text-[#f0f0f5]">Starter Kit</span>
                </div>

                {pack.badge && (
                  <div
                    class="absolute -top-3 left-5 text-xs font-black tracking-widest uppercase px-3 py-1 rounded-full text-[#13131a]"
                    style={`background: ${color};`}
                  >
                    {pack.badge}
                  </div>
                )}

                <!-- Category label + name -->
                <div>
                  <p class="text-xs font-black tracking-widest uppercase mb-1" style={`color: ${color};`}>
                    {categories.find(c => c.id === pack.category)?.label}
                  </p>
                  <h2 class="text-lg font-black text-white leading-snug">{pack.name}</h2>
                  <p class="text-xs text-[#71717a] mt-0.5">{pack.tagline}</p>
                </div>

                <!-- Skills -->
                <ul class="flex flex-col gap-2 flex-1">
                  {pack.skills.map((skill) => {
                    const [title, ...rest] = skill.split(' — ');
                    return (
                      <li class="flex items-start gap-2 text-sm text-[#e2e4f0]">
                        <span
                          class="mt-0.5 w-3.5 h-3.5 shrink-0 rounded-full flex items-center justify-center"
                          style={`background: ${color}18; border: 1px solid ${color}33;`}
                        >
                          <svg class="w-2 h-2" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true" style={`color: ${color};`}>
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                          </svg>
                        </span>
                        <span>
                          <span class="font-semibold text-[#f0f0f5]">{title}</span>
                          {rest.length > 0 && <span class="text-[#e2e4f0]"> — {rest.join(' — ')}</span>}
                        </span>
                      </li>
                    );
                  })}
                </ul>

                <!-- What's included -->
                <div class="border-t border-[#2a2a3d] pt-5 flex flex-col gap-3">
                  <p class="text-xs font-black tracking-widest uppercase text-[#71717a]">This pack will include</p>
                  <ul class="flex flex-col gap-2">
                    {[
                      `${pack.skills.length} pre-configured engrams (Graphnosis .gai files) — sensitivity tiers set for your profession, ready to import`,
                      'Named recall patterns guide — the exact query approach for each skill above',
                      'Connector setup guide — which sources to connect and how to ingest them',
                      'AI session template — local and private AI by design; works with Graphnosis Memory Studio in the free app (source-available under FSL license, verifiable); cloud AI only if approved and configured by your organization',
                      'Setup walkthrough — from install to your first recall in one session',
                      'Memory maintenance — yours to manage in Graphnosis Memory Studio; optionally delegated, deterministically, to the Self-Healing Brain Engine; or non-deterministically enriched by the Neural Network (GNN) and/or Local Layer (GLL)',
                    ].map(item => (
                      <li class="flex items-start gap-2 text-sm text-[#b0b3c6]">
                        <span class="mt-0.5 shrink-0 text-[#5a5a7a]">–</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  <p class="text-sm text-[#9a9db8] leading-relaxed pt-1">
                    Requires the free Graphnosis download — runs entirely on your machine, no cloud, no servers.
                    Your memory stays yours. This kit is a starting point: every engram, schema, and recall pattern
                    it ships with is fully expandable and customizable by you, without limitation, under the free
                    or any tiered plan.
                  </p>
                </div>

                <!-- Price + CTA -->
                <div class="flex items-center justify-between gap-4">
                  <span class="text-3xl font-black text-white">${pack.price}</span>
                  <a
                    href={pack.stripeUrl}
                    class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-full font-bold text-sm transition-opacity hover:opacity-90 text-[#13131a]"
                    style={`background: ${color};`}
                  >
                    Get pack
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>

        <!-- No results -->
        <p id="no-results" class="hidden text-center text-[#52525b] py-16 text-sm">
          No packs match that search. <a href="mailto:templates@graphnosis.com" class="text-[#67e8f9] underline">Request one →</a>
        </p>

      </div>
    </section>

    <!-- Compliance Matrix -->
    <section id="compliance-matrix" class="pb-24 px-4 sm:px-6 scroll-mt-40">
      <div class="max-w-7xl mx-auto">

        <div class="text-center mb-8">
          <h2 class="text-2xl font-black text-white mb-3">Compliance Matrix</h2>
          <p class="text-[#b0b3c6] text-base leading-relaxed max-w-2xl mx-auto">
            How Graphnosis interacts with regulated data across three operating modes.
            Every mode stores data locally and encrypted on your device — the only variable
            is whether an AI model also runs locally (Ollama) or via a cloud API you configure.
          </p>
        </div>

        <!-- Key disclaimer -->
        <div class="bg-[#1c1c27] border border-[#f59e0b]/30 rounded-xl p-5 mb-8 max-w-4xl mx-auto">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 shrink-0 mt-0.5 text-[#f59e0b]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
            <div>
              <p class="text-[#f0f0f5] font-semibold text-sm mb-2">Graphnosis has no servers. Cloud AI is your setup, not ours.</p>
              <p class="text-[#b0b3c6] text-sm leading-relaxed">
                Graphnosis never sends your data to any server. <strong class="text-[#f0f0f5]">"Cloud AI"</strong> in this table refers only to cloud AI clients
                <em>you choose to configure</em> (Claude Desktop, Cursor, ChatGPT, etc.) connected to Graphnosis via MCP.
                When a cloud AI calls <code class="font-mono text-[#67e8f9]">recall</code>, Graphnosis returns only a small excerpt
                (≤50 nodes / ≤8,000 tokens) — never the full database.
                <strong class="text-[#f0f0f5]">Sensitive-tier engrams send zero tokens to cloud AI by default</strong>;
                a consent gate in the app fires before any sensitive data is attached to a prompt.
              </p>
            </div>
          </div>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto rounded-2xl border border-[#2a2a3d]" id="compliance-table-wrap">
          <table class="w-full text-sm border-collapse" id="compliance-table">
            <thead id="compliance-thead">
              <tr class="bg-[#1c1c27] border-b border-[#2a2a3d]">
                <th class="text-left px-5 py-4 text-[#71717a] font-semibold w-2/5">Regulation</th>
                <th class="text-center px-4 py-4 font-semibold" style="color:#67e8f9;">
                  Graphnosis Memory Studio<br /><span class="text-xs text-[#52525b] font-normal">local only · no AI</span>
                </th>
                <th class="text-center px-4 py-4 font-semibold" style="color:#a78bfa;">
                  Local AI + Graphnosis<br /><span class="text-xs text-[#52525b] font-normal">Ollama · air-gapped</span>
                </th>
                <th class="text-center px-4 py-4 font-semibold" style="color:#f59e0b;">
                  Cloud AI + Graphnosis<br /><span class="text-xs text-[#52525b] font-normal">excerpt only · user-configured</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {complianceGroups.map((group, gi) => (
                <>
                  <tr class="bg-[#161620] border-t border-b border-[#2a2a3d]">
                    <td colspan={4} class="px-5 py-2.5 text-xs font-black uppercase tracking-widest text-[#555570]">{group.label}</td>
                  </tr>
                  {group.rows.map((row, ri) => {
                    const sc = statusConfig[row.studio];
                    const lc = statusConfig[row.local];
                    const cc = statusConfig[row.cloud];
                    return (
                      <tr class={`border-t border-[#1e1e2a] ${(ri % 2 === 0) ? 'bg-[#13131a]' : 'bg-[#161620]'}`}>
                        <td class="px-5 py-3 text-[#c4c6d6]">
                          {row.regulation}
                          {row.note && <span class="block text-xs text-[#52525b] mt-0.5">{row.note}</span>}
                        </td>
                        <td class="text-center px-3 py-3">
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" style={`background:${sc.bg}18; color:${sc.bg}; border:1px solid ${sc.bg}30;`}>{sc.label}</span>
                        </td>
                        <td class="text-center px-3 py-3">
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" style={`background:${lc.bg}18; color:${lc.bg}; border:1px solid ${lc.bg}30;`}>{lc.label}</span>
                        </td>
                        <td class="text-center px-3 py-3">
                          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold" style={`background:${cc.bg}18; color:${cc.bg}; border:1px solid ${cc.bg}30;`}>
                            {cc.label}{row.cloudNote ?? ''}
                          </span>
                        </td>
                      </tr>
                    );
                  })}
                </>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Footnotes -->
        <div class="mt-6 max-w-4xl mx-auto flex flex-col gap-2 text-sm text-[#9a9db8]">
          <p>¹ Requires a Business Associate Agreement (BAA) with your cloud AI provider. Anthropic Enterprise and OpenAI Enterprise offer BAAs.</p>
          <p>² Requires a Data Processing Agreement (DPA) with your cloud AI provider.</p>
          <p>³ A small recall excerpt reaches the cloud provider's infrastructure. Legal review recommended for your specific context.</p>
          <p>⁴ Compatibility depends on your cloud AI provider's own certifications for the relevant standard.</p>
          <p class="mt-2 text-[#71717a] italic">This matrix is informational only and does not constitute legal advice. Consult your compliance officer for your specific context.</p>
        </div>

      </div>
    </section>

    <!-- Business Case for IT -->
    <section id="it-business-case" class="pb-24 px-4 sm:px-6 scroll-mt-40">
      <div class="max-w-4xl mx-auto">

        <div class="text-center mb-10">
          <p class="text-xs font-black tracking-widest uppercase text-[#67e8f9] mb-3">For the IT approval conversation</p>
          <h2 class="text-2xl font-black text-white mb-3">Business Case for Your IT Department</h2>
          <p class="text-[#b0b3c6] text-base leading-relaxed max-w-xl mx-auto">
            The questions IT will ask — and why Graphnosis passes every one of them.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
          {[
            {
