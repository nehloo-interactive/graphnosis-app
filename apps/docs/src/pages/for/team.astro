---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import PersonaPage from '../../components/PersonaPage.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Graphnosis for Teams — shared job memory for dev squads, consultants & project teams"
  description="How Graphnosis works for small teams: scoped shared engrams, decision logs, meeting memory, and cross-tool context across Slack, GitHub, and Jira."
>
  <Nav />
  <main>
    <PersonaPage
      active="team"
      headline="Shared memory for your whole team"
      categories="startup teams · dev squads · project managers · consultants · agencies · freelance duos"
      tagline="Give your team a single, encrypted, on-premise memory layer — shared across AI clients, indexed deterministically, with per-person access control. No cloud sync. No vendor lock-in."
      useCases={[
        {
          title: 'Decision logs that don\'t get lost',
          body: 'Every architecture decision, product call, or client agreement is stored once and recalled by any team member\'s AI — with full provenance.',
        },
        {
          title: 'Meeting memory',
          body: 'Ingest meeting notes, action items, and retrospective outputs. Ask "what did we decide about the auth layer in Q3?" and get the exact answer.',
        },
        {
          title: 'Cross-tool context',
          body: 'Slack threads, GitHub ADRs, Jira tickets, and Confluence pages all feed one shared memory. Your AI already knows the full context before you ask.',
        },
        {
          title: 'Client & project memory',
          body: 'Consultants and agencies keep a separate engram per client. Switch projects and your AI knows the right context immediately.',
        },
      ]}
      differentiators={[
        'Scoped sharing tokens let teammates access specific engrams from their own AI clients — editor or viewer role per person.',
        'Team Admin panel shows per-token active sessions so you always know who\'s connected.',
        'On-premise: memory never leaves your server, your VPN, or your machine.',
      ]}
      sharedEngrams={`The core feature for teams: generate scoped bearer tokens (editor for contributors, viewer for stakeholders) scoped to specific engrams. Each teammate connects their own AI client with their token — full access to shared memory, zero access to anything outside their scope. The Team Admin panel shows live active sessions per token.`}
      proHighlight={`Teams tier unlocks shared engrams, the Team Admin panel, memory-trained Skills & SOPs for onboarding, Job Memory Kits for fast setup, and the Memory Studio graph view. Everything a growing team needs to work smarter with AI.`}
      links={[
        { label: 'Getting Started',         href: '/getting-started/overview' },
        { label: 'Connect Your AI',         href: '/getting-started/connect-ai' },
        { label: 'Job Memory Kits',         href: '/job-memory-kits' },
        { label: 'Memory-trained Skills',   href: '/skills-goals-trainer' },
        { label: 'Memory Studio',           href: '/memory-studio' },
        { label: 'AI Access Controls',      href: '/guides/ai-access-controls' },
        { label: 'Upgrade to Pro / Teams',  href: '/upgrade' },
      ]}
      cta={{ label: 'Upgrade to Teams', href: '/upgrade' }}
    />
  </main>
  <Footer />
</Layout>
