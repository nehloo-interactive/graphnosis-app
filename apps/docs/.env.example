# ── Graphnosis billing env (apps/docs on Cloudflare Pages / Workers) ─────────
#
# These vars power the Stripe Checkout + webhook + Ed25519 token-mint endpoints
# under /upgrade, /api/stripe/*, /api/auth/*, /api/subscription/*, /claim.
# The Starlight docs pages do NOT need any of these — they prerender statically.
#
# In production these live in Cloudflare:
#   Workers & Pages → graphnosis-docs → Settings → Variables and Secrets.
#     - Mark each secret value (STRIPE_*, RESEND_*, LICENSE_*) as type "Secret".
#     - Plain-text values (PUBLIC_*, RESEND_FROM_ADDRESS, STRIPE_PRICE_*) can
#       be type "Plain text" — easier to read/edit later.
#
# For local dev with `wrangler pages dev`, copy this file to apps/docs/.env
# (gitignored) and fill in real values.

# ── Public (browser-exposed) ──────────────────────────────────────────────────

# Canonical billing base URL. The desktop app reads this via PUBLIC_BILLING_BASE_URL
# at build time (apps/desktop/.env) to derive the Upgrade button target and the
# status-poll endpoint. The web side uses it to build success/cancel URLs.
PUBLIC_BILLING_BASE_URL=https://graphnosis.com

# Stripe-hosted Customer Portal login URL. The /account route (the desktop's
# "Manage or cancel subscription" button) 303-redirects here, so billing
# identity lives entirely with Stripe and Graphnosis serves no account page.
# Create it in Stripe Dashboard → Settings → Billing → Customer portal.
STRIPE_PORTAL_LOGIN_URL=https://billing.stripe.com/p/login/REPLACE_ME

# ── Stripe ────────────────────────────────────────────────────────────────────

# Test-mode keys (sk_test_…) for dev; live-mode keys for production. Workers
# pick whichever set is in the active environment.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Price IDs — create each in your Stripe dashboard and paste the IDs here.
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_TEAMS_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_TEAMS_ANNUAL=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_REPLACE_ME

# ── Ed25519 license signing keypair ───────────────────────────────────────────
#
# Generate ONCE and store the secret key as a Cloudflare Secret:
#
#   node --input-type=module << 'EOF'
#     const { privateKey, publicKey } = await crypto.subtle.generateKey('Ed25519', true, ['sign', 'verify']);
#     const privDer = Buffer.from(await crypto.subtle.exportKey('pkcs8', privateKey));
#     const pubRaw  = Buffer.from(await crypto.subtle.exportKey('raw',   publicKey));
#     const seed    = privDer.slice(16);                             // strip 16-byte PKCS#8 header
#     const secretKeyHex = Buffer.from([...seed, ...pubRaw]).toString('hex');
#     console.log('Public key (hex):', pubRaw.toString('hex'));      // 64 hex chars
#     console.log('Secret key (hex):', secretKeyHex);               // 128 hex chars
#   EOF
#
# The public key (64 hex chars) MUST also be pasted into the desktop sidecar at
# apps/desktop-sidecar/src/license-validator.ts (SIGNING_PUBLIC_KEY bytes).
# The secret key (128 hex chars = 64 raw bytes) stays here and NEVER leaves
# server-side env.

LICENSE_SIGNING_SECRET_KEY_HEX=REPLACE_ME_128_HEX_CHARS

# ── Magic link / email delivery ───────────────────────────────────────────────
#
# Resend (https://resend.com) — pure HTTP API, Workers-compatible. Swap by
# editing apps/docs/src/server/email.ts.

RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_ADDRESS=support@graphnosis.com

# Resend segment ids for the /subscribe route (newsletter form + enterprise
# waitlist on the marketing pages). Plain vars, not secrets.
RESEND_NEWSLETTER_SEGMENT_ID=seg_REPLACE_ME
RESEND_ENTERPRISE_SEGMENT_ID=seg_REPLACE_ME

# ── Admin API ─────────────────────────────────────────────────────────────────
#
# Protects /api/admin/* endpoints (grant seats, manage groups, domain allowlist).
# Use: Authorization: Bearer <key>  on every request.
# Generate with: openssl rand -hex 32

ADMIN_API_KEY=REPLACE_ME

# Gates GET /api/pack-stats (anonymous .gsk download counters).
# Generate with: openssl rand -hex 32
PACK_STATS_ADMIN_SECRET=REPLACE_ME

# ── Stripe coupons (optional, for pre-applied discount URLs) ──────────────────
#
# Comma-separated SLUG=STRIPE_COUPON_ID pairs. When /upgrade/checkout?coupon=SLUG
# is requested, the coupon is automatically applied to the session.
# Create coupon IDs in the Stripe Dashboard → Products → Coupons.
#
# Example: STRIPE_COUPONS=PARTNER50=coupon_abc123,LAUNCH=coupon_xyz456

# STRIPE_COUPONS=

# ── Cloudflare KV (not an env var — a binding) ────────────────────────────────
#
# Run this once before your first deploy:
#
#   wrangler kv namespace create BILLING_KV
#   wrangler kv namespace create BILLING_KV --preview
#
# Then paste the returned ids into apps/docs/wrangler.toml under the
# [[kv_namespaces]] block. Pages picks the binding up automatically;
# nothing else to set.
