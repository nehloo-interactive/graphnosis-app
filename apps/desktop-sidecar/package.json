{
  "name": "@graphnosis-app/desktop-sidecar",
  "version": "1.15.0",
  "private": true,
  "type": "module",
  "author": "Nehloo Interactive LLC",
  "license": "SEE LICENSE IN ../../LICENSE",
  "main": "./dist/index.js",
  "bin": {
    "graphnosis-sidecar": "./dist/index.js",
    "graphnosis-mcp-relay": "./dist/mcp-relay.js"
  },
  "scripts": {
    "build": "node scripts/generate-docs-content.mjs && node scripts/generate-skill-demos-content.mjs && tsc -p tsconfig.json",
    "dev": "node --watch --enable-source-maps --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "smoke": "node --enable-source-maps dist/smoketest.js",
    "smoke:brain": "node --enable-source-maps dist/smoketest-brain.js",
    "smoke:license": "node --enable-source-maps dist/smoketest-license.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@graphnosis-app/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mozilla/readability": "^0.6.0",
    "@nehloo-interactive/graphnosis-secure-sync": "https://github.com/nehloo-interactive/graphnosis-secure-sync.git#v0.2.1",
    "@nehloo/graphnosis": "^0.6.1",
    "@scure/bip39": "^1.4.0",
    "@simplewebauthn/server": "^13.3.1",
    "fastembed": "^2.1.0",
    "fflate": "^0.8.3",
    "jsdom": "^24.0.0",
    "libsodium-wrappers-sumo": "^0.7.16",
    "mammoth": "^1.12.0",
    "proper-lockfile": "^4.1.2",
    "reflect-metadata": "^0.2.2",
    "unpdf": "^1.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.0",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/node": "^20.11.0",
    "@types/proper-lockfile": "^4.1.4",
    "esbuild": "^0.24.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
