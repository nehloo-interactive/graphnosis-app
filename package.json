{
  "name": "graphnosis-app",
  "version": "1.14.3",
  "private": true,
  "description": "Personal second-memory desktop app powered by Graphnosis. Local-first, encrypted, multi-graph, attaches relevant subgraph context to any MCP-aware AI.",
  "author": "Nehloo Interactive LLC",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "sbom": "npx --yes @cyclonedx/cdxgen -t js -o sbom.cdx.json",
    "licenses": "pnpm licenses list --prod --long",
    "dev:sidecar": "pnpm --filter @graphnosis-app/desktop-sidecar dev",
    "dev:desktop": "pnpm --filter @graphnosis-app/desktop tauri:dev",
    "typecheck": "pnpm -r typecheck",
    "test:all": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/run-all.ts",
    "test:recall": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/recall.test.ts",
    "test:variants": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/recall-variants.test.ts",
    "test:sources": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/sources.test.ts",
    "test:metadata": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/metadata.test.ts",
    "test:duplicates": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/duplicates.test.ts",
    "test:mutations": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/mutations.test.ts",
    "test:persistence": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/persistence.test.ts",
    "test:concurrency": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/concurrency.test.ts",
    "test:settings": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/settings-matrix.test.ts",
    "test:edge": "pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/edge-cases.test.ts",
    "test:llm": "GRAPHNOSIS_OLLAMA=1 pnpm --filter @graphnosis-app/desktop-sidecar build && tsx tests/llm.test.ts",
    "release:sync-downloads": "node apps/docs/scripts/sync-graphnosis-md.mjs",
    "mcpb:build": "pnpm --filter @graphnosis-app/desktop-sidecar build && node apps/desktop-sidecar/scripts/mcpb-build.mjs",
    "mcpb:pack": "cd mcpb && mcpb pack . ../graphnosis.mcpb && echo Done: graphnosis.mcpb"
  },
  "devDependencies": {
    "tsx": "^4.22.3"
  }
}
