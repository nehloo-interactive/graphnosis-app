# Graphnosis personal server — environment config
# Copy to /etc/graphnosis/server.env and `sudo chmod 600` it (contains secrets).

# ── Cortex (required) ────────────────────────────────────────────────────────
# Path to the encrypted cortex directory on this machine's disk.
GRAPHNOSIS_CORTEX=/var/lib/graphnosis/cortex

# Passphrase to unlock the cortex at boot. OPTIONAL — and a security tradeoff:
# storing it here lets the service auto-unlock without human interaction, but
# it sits in plaintext in this file (hence chmod 600 + a dedicated user).
# Omit it to require a manual unlock from the browser after each restart.
GRAPHNOSIS_PASSPHRASE=change-me

# ── Browser UI (required for server mode) ────────────────────────────────────
GRAPHNOSIS_HTTP_UI=1

# Bind address. 0.0.0.0 = reachable from other devices on the LAN / Tailscale
# (the whole point of server mode), gated by the access token below.
# Use 127.0.0.1 to restrict to this machine only.
GRAPHNOSIS_BIND=0.0.0.0

# Port for the browser UI + JSON-RPC API (kept separate from MCP on :3457).
GRAPHNOSIS_HTTP_UI_PORT=3456

# Static access token a browser exchanges for a session. Generate a strong one:
#   openssl rand -hex 32
# Clients open  http://<host>:3456/?token=<this>  (or paste it on the lock screen).
GRAPHNOSIS_HTTP_UI_TOKEN=replace-with-openssl-rand-hex-32

# Absolute path to the compiled web UI (produced by `pnpm -r build`).
GRAPHNOSIS_HTTP_UI_STATIC=/opt/graphnosis/GraphnosisApp/apps/desktop/dist

# ── Optional ─────────────────────────────────────────────────────────────────
# Default engram to load first.
# GRAPHNOSIS_DEFAULT_GRAPH=personal
# Embedding worker count (default 2).
# GRAPHNOSIS_EMBED_WORKERS=2
