node_modules/
dist/
build/
out/
.turbo/
.tauri/
target/
*.log
.DS_Store
.env
.env.*
!.env.example


# App user data (must never be committed)
*.gai
*.aikg
*.embcache
*.oplog
*.bundle
*.enc
salt.bin
recovery-*.txt

# Tauri build artifacts produced by build.rs at compile time. The Bun-compiled
# sidecar + MCP relay (~80 MB each) and the Swift biometric sidecar are
# rebuilt on every `cargo build` from `apps/desktop-sidecar/src/` and the
# Swift sources — keeping them in git would bloat the repo and create
# merge conflicts on every dev iteration.
apps/desktop/src-tauri/binaries/

# Native shared libraries copied from node_modules by build.rs (≈30 MB).
# The dylib is re-staged on every build so the bundler picks it up; the
# source of truth is node_modules/.pnpm/onnxruntime-node@.../.
apps/desktop/src-tauri/resources/libonnxruntime.*.dylib

# Astro build cache for the docs site.
.astro/

# Generated copy of the canonical repo-root GRAPHNOSIS.md, synced into the
# docs site's public/ folder by apps/docs/scripts/sync-graphnosis-md.mjs
# before every dev/build. The source of truth is /GRAPHNOSIS.md — this copy
# must never be edited by hand or committed.
apps/docs/public/GRAPHNOSIS.md

# Marketing website — separate repo / deployment, not part of this monorepo.
apps/marketing-web/

# Claude Code session artifacts — local agent worktrees + transcripts.
.claude/

# Distribution artifacts (DMG / .app.tar.gz / .sig) that get rebuilt on
# every `pnpm tauri:build` or `hdiutil create`. Lives at repo root for
# easy AirDrop / scp / upload; never committed.
/releases/
*.dmg
*.app.tar.gz
*.app.tar.gz.sig

# GTS skill pack content and build artifacts.
#
# *.gts                            — compiled binary packs (AES-256-GCM encrypted)
# default-skill-packs.ts           — skill content instances (text, recipes) authored
#                                    locally, verified, compiled — never committed.
#                                    Only default-skill-pack-types.ts (pure schema)
#                                    is committed.
# default-skill-packs-content.*    — any staging variant of the content file
# default-skill-packs/             — directory form of the same
# scripts/gts-content/             — staging area used by build-gts.mjs
# dist/packs/                      — compiled .gts output directory
*.gts
apps/desktop-sidecar/src/default-skill-packs.ts
apps/desktop-sidecar/src/default-skill-packs-content.*
apps/desktop-sidecar/src/default-skill-packs/
scripts/gts-content/
dist/packs/

